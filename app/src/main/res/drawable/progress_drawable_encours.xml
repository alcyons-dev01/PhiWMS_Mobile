<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fond (arrière-plan de la barre) -->
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <corners android:radius="12dp"/> <!-- Arrondi -->
            <solid android:color="#E0E0E0"/> <!-- Gris clair par défaut -->
        </shape>
    </item>

    <!-- Barre de progression -->
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <corners android:radius="12dp"/> <!-- même arrondi -->
                <solid android:color="@color/bleu_clair_alcyons"/> <!-- couleur modifiable -->
            </shape>
        </clip>
    </item>
</layer-list>