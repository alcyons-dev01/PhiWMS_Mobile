<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:bottom="1dp"
        android:left="-3dp"
        android:right="-3dp"
        android:top="-3dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1.5dp"
                android:color="@android:color/black" />
            <stroke
                android:width="1dp"
                android:color="@android:color/darker_gray" />
            <padding
                android:left="0dp"
                android:right="5dp"
                android:top="5dp" />
        </shape>
    </item>
</layer-list>