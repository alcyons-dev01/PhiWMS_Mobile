<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shape principal avec vraies bordures et radius -->
    <item>
        <shape>
            <solid android:color="#FFFFFF"/>
            <stroke
                android:width="1dp"
                android:color="#2AA7FF"/>
            <corners
                android:bottomLeftRadius="10dp"
                android:bottomRightRadius="10dp"/>
        </shape>
    </item>

    <!-- Masque de la bordure du haut -->
    <item
        android:top="0dp"
        android:left="1dp"
        android:right="1dp"
        android:height="1dp"
        android:gravity="top">
        <shape>
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>

</layer-list>