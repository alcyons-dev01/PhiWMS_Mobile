<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#F0F4FF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══════════════════════════════
                 HEADER : titre + annuler
            ═══════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/bleu_fonce_alcyons"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Commentaire"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/layoutFermePAD"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ANNULER"
                    android:textColor="@color/rouge"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:alpha="0.9" />

            </LinearLayout>

            <!-- Séparateur accent -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/bleu_clair_alcyons" />

            <!-- ═══════════════════════════════
                 ZONE COMMENTAIRE
            ═══════════════════════════════ -->
            <EditText
                android:id="@+id/commentaireEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Saisir un commentaire"
                android:lines="10"
                android:imeOptions="actionDone"
                android:background="@null"
                android:textColor="@color/bleu_fonce_alcyons"
                android:textColorHint="#90A4AE"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp" />

            <!-- Séparateur fin -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/bleu_clair_alcyons_transparent"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="8dp" />

            <!-- ═══════════════════════════════
                 BOUTONS : Photo + Valider
            ═══════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingBottom="14dp"
                android:weightSum="2">

                <!-- Bouton photo -->
                <LinearLayout
                    android:id="@+id/boutonPhoto"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@color/bleu_fonce_alcyons"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/ic_photo_camera"
                        android:backgroundTint="#FFFFFF"
                        android:contentDescription="@null" />

                </LinearLayout>

                <!-- Bouton valider -->
                <Button
                    android:id="@+id/boutonValider"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="Valider"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:background="@color/vert" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>