<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:backgroundTint="@android:color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/background_element_liste"
        android:padding="5dp">

        <TextView
            android:id="@+id/designationProduit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:gravity="center_vertical"
            android:paddingRight="5dp"
            android:text="Designation"
            android:textColor="@android:color/black"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/zoneReferences"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/designationProduit"
            android:orientation="horizontal"
            android:weightSum="10">

            <TextView
                android:id="@+id/referenceProduit"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_weight="5"
                android:text="ReferenceProduit" />

            <TextView
                android:id="@+id/nomFournisseur"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_weight="5"
                android:text="Fournisseur"
                android:textColor="@android:color/black" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/zoneDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/zoneReferences"
            android:orientation="horizontal"
            android:weightSum="10">

            <LinearLayout
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_weight="5">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="5dp"
                    android:text="Lot" />

                <TextView
                    android:id="@+id/lotRetourne"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lot retourné"
                    android:textColor="@android:color/black" />


            </LinearLayout>

            <LinearLayout
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_weight="5">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="5dp"
                    android:text="Exp." />

                <TextView
                    android:id="@+id/datePeremption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DatePeremption"
                    android:textColor="@android:color/holo_red_light" />

            </LinearLayout>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/zoneDate"
            android:orientation="horizontal"
            android:weightSum="4">

            <LinearLayout
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:orientation="vertical"
                android:padding="2dp">


            </LinearLayout>

            <LinearLayout
                android:id="@+id/linearQteDestruction"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:orientation="vertical"
                android:padding="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Qté retournée" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_marginLeft="45dp"
                    android:layout_marginRight="45dp"
                    android:background="@color/rouge2" />

                <TextView
                    android:id="@+id/QteRetourner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/rouge2"
                    android:gravity="center"
                    android:text="QteRetourner"
                    android:textColor="@color/rouge2"
                    android:textSize="17sp" />

            </LinearLayout>

        </LinearLayout>


    </RelativeLayout>

</RelativeLayout>