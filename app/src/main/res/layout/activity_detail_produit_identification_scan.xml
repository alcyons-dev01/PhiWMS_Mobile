<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context="fr.alcyons.phiwms_mobile.IdentificationParScan.DetailProduitIdentificationParScanActivity">

    <androidx.cardview.widget.CardView
        android:id="@+id/barreDeTitre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="10dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#F0F4FF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/nomProduit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Designation produit longue sur plusieurs lignes si besoin"
                android:textStyle="bold"
                android:maxLines="3"
                android:ellipsize="end"
                android:textColor="@color/bleu_fonce_alcyons"
                android:textSize="15sp"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/referenceFournisseur"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="REF-001234"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="11sp"
                    android:alpha="0.7"/>

                <TextView
                    android:id="@+id/nomFournisseur"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="Fournisseur"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="11sp"
                    android:alpha="0.7"/>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="4dp"
                android:background="@color/bleu_clair_alcyons_transparent" />

            <LinearLayout
                android:id="@+id/zoneCategorie"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Catégorie"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="10sp"
                    android:alpha="0.6" />

                <TextView
                    android:id="@+id/categorie"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:gravity="end"
                    android:ellipsize="end" />

            </LinearLayout>

            <View
                android:id="@+id/separateurCategorie"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="4dp"
                android:background="@color/bleu_clair_alcyons_transparent" />

            <LinearLayout
                android:id="@+id/zoneClassATC"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="visible"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Classe ATC"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="10sp"
                    android:alpha="0.6" />

                <TextView
                    android:id="@+id/classATC"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text=""
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <View
                android:id="@+id/separateurATC"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="4dp"
                android:background="@color/bleu_clair_alcyons_transparent" />

            <LinearLayout
                android:id="@+id/zoneDCI"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="visible"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DCI"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="10sp"
                    android:alpha="0.6" />

                <TextView
                    android:id="@+id/dci"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:gravity="end"
                    android:ellipsize="end" />

            </LinearLayout>

        </LinearLayout>


    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/zoneCodeGS1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/barreDeTitre"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:id="@+id/layoutcodeGS1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:visibility="visible"
            android:layout_gravity="center_vertical">

            <TextView
                android:id="@+id/codeGS1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text=""
                android:textColor="@color/bleu_fonce_alcyons"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_gravity="center_vertical"/>

            <ImageView
                android:id="@+id/suppressioncodescanne"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:background="@drawable/ic_croix_noir"
                android:visibility="visible" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/layouteditcode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/zoneCodeGS1"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:background="@drawable/background_cadre_vert"
        android:padding="10dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/editcodescanne"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingLeft="10dp" />

    </LinearLayout>

    <RelativeLayout
        android:id="@+id/contenuPage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/zoneCodeGS1"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:id="@+id/layoutIdentification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="8dp">

            <TextView
                android:id="@+id/warningNonIdentifie"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_cadre_rouge"
                android:backgroundTint="@color/rouge"
                android:gravity="center"
                android:padding="12dp"
                android:text="RÉFÉRENCE IDENTIFIÉE"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/referenceIdentifie"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_cadre_vert"
                android:backgroundTint="@color/vert"
                android:gravity="center"
                android:padding="12dp"
                android:text="RÉFÉRENCE IDENTIFIÉE"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <TextView
                android:id="@+id/referenceEnCoursIdentification"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_cadre_bleu"
                android:backgroundTint="@color/bleu_clair_alcyons"
                android:gravity="center"
                android:padding="12dp"
                android:text="RÉFÉRENCE EN COURS D'IDENTIFICATION"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>

        <ImageView
            android:id="@+id/boutonValidation"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_marginBottom="20dp"
            android:background="@drawable/ic_check_circle_green"
            android:backgroundTint="@color/vert" />

    </RelativeLayout>

</RelativeLayout>