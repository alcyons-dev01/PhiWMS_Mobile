<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="6dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#F0F4FF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══════════════════════════════
                 BANDEAU URGENT (gone par défaut)
            ═══════════════════════════════ -->
            <LinearLayout
                android:id="@+id/zoneIsUrgent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#C62828"
                android:paddingVertical="6dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/isUrgent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="URGENT"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

            </LinearLayout>

            <!-- ═══════════════════════════════
                 HEADER : N° uid + Dépôt
            ═══════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bleu_fonce_alcyons"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:weightSum="2">

                <TextView
                    android:id="@+id/uidPHPreparation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.75"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/nomDepot"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.25"
                    android:gravity="end"
                    android:text=""
                    android:textColor="#BBDEFB"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <!-- Séparateur accent -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/bleu_clair_alcyons" />

            <!-- ═══════════════════════════════
                 CORPS
            ═══════════════════════════════ -->
            <LinearLayout
                android:id="@+id/zoneGauche"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp">

                <!-- Liste -->
                <TextView
                    android:id="@+id/liste"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="13sp"
                    android:layout_marginBottom="8dp" />

                <!-- Séparateur fin -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bleu_clair_alcyons_transparent"
                    android:layout_marginBottom="8dp" />

                <!-- Dépôt origine -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dépôt origine : "
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="12sp"
                        android:alpha="0.7" />

                    <TextView
                        android:id="@+id/origine"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>