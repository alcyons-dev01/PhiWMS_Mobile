<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <ImageView
            android:id="@+id/iconeService"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:backgroundTint="@color/bleu_fonce_alcyons"
            android:layout_marginEnd="14dp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/nomPerimetre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/bleu_fonce_alcyons"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

    </LinearLayout>

    <!-- Séparateur -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/bleu_clair_alcyons_transparent"
        android:layout_marginHorizontal="16dp"/>

</LinearLayout>