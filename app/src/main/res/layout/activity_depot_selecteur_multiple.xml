<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- ═══════════════════════════════
         BARRE DE TITRE
    ═══════════════════════════════ -->
    <LinearLayout
        android:id="@+id/barreDeTitre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bleu_fonce_alcyons"
        android:orientation="vertical"
        android:paddingVertical="14dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sélectionnez un dépôt"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Séparateur accent -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/bleu_clair_alcyons" />

    <!-- ═══════════════════════════════
         LISTE EXPANDABLE
    ═══════════════════════════════ -->
    <ExpandableListView
        android:id="@+id/expandableListViewDepot"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:childDivider="@color/bleu_clair_alcyons_transparent"
        android:divider="@color/bleu_clair_alcyons_transparent"
        android:dividerHeight="1dp"
        android:background="#FFFFFF"
        android:paddingTop="6dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        android:indicatorLeft="?android:attr/expandableListPreferredItemIndicatorLeft" />

    <!-- FAB géolocalisation -->
    <!--<com.github.clans.fab.FloatingActionButton
        android:id="@+id/boutonGeolocalisation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_location_black"
        app:fab_colorNormal="@android:color/white"
        app:fab_colorPressed="@color/bleu_clair_alcyons"
        app:fab_colorRipple="@color/bleu_clair_alcyons_transparent"
        app:fab_size="normal" />-->

</LinearLayout>