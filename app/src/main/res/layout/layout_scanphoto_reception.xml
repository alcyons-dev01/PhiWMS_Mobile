<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- LAYOUT FILM VALIDATION -->
    <LinearLayout
        android:id="@+id/layoutFondValidation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/vert"
        android:orientation="vertical"
        android:alpha="0.7"
        android:visibility="gone"/>
    <LinearLayout
        android:id="@+id/layoutIconeValidation"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="visible"
        android:layout_alignParentBottom="true"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/designationValidation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/blanc"
            android:textSize="18dp"
            android:gravity="center"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"
            android:text=""/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_vertical"
            android:layout_marginTop="10dp"
            android:paddingStart="10dp"
            android:weightSum="3">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="left"
                android:text="Lot : "
                android:textColor="@color/blanc"
                android:textSize="16dp"/>

            <TextView
                android:id="@+id/lotValidation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="2"
                android:gravity="left"
                android:text=""
                android:textColor="@color/blanc"
                android:textSize="18dp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginTop="10dp"
            android:paddingStart="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/blanc"
                android:textSize="16dp"
                android:gravity="left"
                android:layout_gravity="center_vertical"
                android:text="Date Exp. : "/>

            <TextView
                android:id="@+id/peremptionValidation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textColor="@color/blanc"
                android:textSize="18dp"
                android:gravity="left"
                android:textStyle="bold"
                android:layout_gravity="center_vertical"
                android:text=""/>


        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutSerieValidation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginTop="10dp"
            android:paddingStart="10dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/blanc"
                android:textSize="16dp"
                android:gravity="left"
                android:layout_gravity="center_vertical"
                android:text="Série : "/>

            <TextView
                android:id="@+id/serieValidation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textColor="@color/blanc"
                android:textSize="18dp"
                android:gravity="left"
                android:textStyle="bold"
                android:layout_gravity="center_vertical"
                android:text="numSerie"/>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginTop="10dp"
            android:paddingStart="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/blanc"
                android:textSize="16dp"
                android:gravity="left"
                android:layout_gravity="center_vertical"
                android:text="Place : "/>

            <TextView
                android:id="@+id/emplacementValidation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textColor="@color/blanc"
                android:textSize="18dp"
                android:gravity="left"
                android:textStyle="bold"
                android:layout_gravity="center_vertical"
                android:text=""/>

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBarQuantite"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="20dp"
            android:max="5"
            android:progress="0"
            android:indeterminate="false"
            android:progressDrawable="@drawable/progress_drawable_encours"/>

        <TextView
            android:id="@+id/quantiteValidation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            android:layout_gravity="center_vertical"
            android:text=""/>

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/validate_bleu"
            android:layout_centerInParent="true"
            android:layout_marginTop="20dp"
            android:layout_gravity="center"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- LAYOUT FILM PRODUIT COMPLET -->
    <LinearLayout
        android:id="@+id/layoutProduitComplet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <ImageView
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/validate"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:visibility="visible"/>

        <TextView
            android:id="@+id/designationComplete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text=""/>


        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="14dp"
            android:layout_marginHorizontal="15dp"
            android:max="5"
            android:progress="5"
            android:indeterminate="false"
            android:progressTint="@color/vert"
            android:progressDrawable="@drawable/progress_drawable_encours"/>

        <TextView
            android:id="@+id/quantiteComplete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/blanc"
            android:textSize="32dp"
            android:gravity="center"
            android:textStyle="bold"
            android:layout_gravity="center_vertical"
            android:text=""/>

    </LinearLayout>

    <!-- LAYOUT FILM PRODUIT ABSENT -->
    <LinearLayout
        android:id="@+id/layoutProduitAbsent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <ImageView
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/ic_croix_rouge"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:visibility="visible"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text="Référence absente\nde la réception"/>

    </LinearLayout>

    <!-- LAYOUT FILM LOT ABSENT -->
    <LinearLayout
        android:id="@+id/layoutLotAbsent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <ImageView
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/ic_croix_rouge"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:visibility="visible"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text="Lot absent\nde vos stocks"/>

    </LinearLayout>

    <!-- LAYOUT FILM PRODUIT INCONNU -->
    <LinearLayout
        android:id="@+id/layoutProduitInconnu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <ImageView
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/ic_croix_rouge"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:visibility="visible"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text="Référence inconnue\nen base de données"/>

    </LinearLayout>

    <!-- LAYOUT FILM SCANNER EMPLACEMENT -->
    <LinearLayout
        android:id="@+id/layoutScannerEmplacement"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <ImageView
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:background="@drawable/phitagplace"
            android:visibility="visible"
            android:layout_gravity="center"
            android:layout_centerInParent="true"
            android:layout_below="@+id/LinearLayoutBoutonBarcode" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text="Scannez un\nemplacement"/>

    </LinearLayout>

    <!-- LAYOUT FILM SCANNER EMPLACEMENT -->
    <LinearLayout
        android:id="@+id/layoutScannerEmplacementInconnu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/phitagplace"
                    android:visibility="visible"
                    android:layout_gravity="center"
                    android:layout_centerInParent="true"
                    android:layout_below="@+id/LinearLayoutBoutonBarcode"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/ic_croix_rouge"
                    android:visibility="visible"
                    android:layout_gravity="center"
                    android:layout_centerInParent="true"
                    android:layout_below="@+id/LinearLayoutBoutonBarcode"/>

            </LinearLayout>


        </LinearLayout>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text="Emplacement scanné inconnu"/>

    </LinearLayout>

    <!-- LAYOUT FILM SERIE SCANNEE -->
    <LinearLayout
        android:id="@+id/layoutSerieScannee"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <ImageView
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/ic_croix_rouge"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:visibility="visible"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text="Numéro de série\ndéjà scanné"/>
    </LinearLayout>

    <!-- LAYOUT FILM SERIE NON SCANNEE -->
    <LinearLayout
        android:id="@+id/layoutSerieNonScannee"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <ImageView
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/ic_croix_rouge"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:visibility="visible"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text="Numéro de série\nabsent du scan"/>

    </LinearLayout>

</RelativeLayout>