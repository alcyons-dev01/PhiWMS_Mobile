<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F0F4FF">

    <!-- Contenu principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <!-- 3/4 gauche : Lot + Péremption + Zone + Emplacement -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:orientation="vertical"
            android:paddingEnd="8dp">

            <!-- Ligne 1 : Numéro de lot + Date péremption -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/lotNumero_TV"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="LOT-2024-001"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/peremption_TV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="04/2026"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="12sp"
                    android:alpha="0.8"/>

            </LinearLayout>



            <!-- Ligne 2 : Zone + Emplacement -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/zone_TV"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Zone A"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="11sp"
                    android:alpha="0.7"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/emplacement_TV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMP-001"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="11sp"
                    android:alpha="0.7"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Séparateur vertical -->
        <View
            android:id="@+id/separateurVertical_V"
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/bleu_clair_alcyons_transparent"
            android:layout_marginHorizontal="6dp"/>

        <!-- 1/4 droit : Quantité -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardViewQuantite"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/bleu_fonce_alcyons">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/quantite_TV"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="120"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Qté"
                    android:textColor="#AAAAFF"
                    android:textSize="8sp"
                    android:gravity="center"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Séparateur entre items -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/bleu_fonce_alcyons"
        android:layout_marginHorizontal="8dp"/>

</LinearLayout>