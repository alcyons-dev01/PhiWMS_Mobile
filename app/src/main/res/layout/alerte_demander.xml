<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#F0F4FF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══════════════════════════════
                 HEADER : désignation + fermer
            ═══════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/bleu_fonce_alcyons"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/np_designation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:text=""
                    android:textColor="#FFFFFF" />

                <ImageView
                    android:id="@+id/np_quitterModale"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/ic_clear"
                    android:backgroundTint="#FFFFFF"
                    android:contentDescription="@null" />

            </LinearLayout>

            <!-- Séparateur accent -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/bleu_clair_alcyons" />

            <!-- ═══════════════════════════════
                 Référence + Conditionnement
            ═══════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp">

                <TextView
                    android:id="@+id/np_reference"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:alpha="0.7" />

                <TextView
                    android:id="@+id/np_conditionnement"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:text=""
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:alpha="0.7"
                    android:gravity="end" />

            </LinearLayout>

            <!-- Séparateur fin -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/bleu_clair_alcyons_transparent"
                android:layout_marginHorizontal="14dp" />

            <!-- ═══════════════════════════════
                 ZONE STOCK
            ═══════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutStock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="14dp"
                android:paddingBottom="6dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Saisissez votre stock"
                    android:textSize="14sp"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/np_qteStock"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:text=""
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:inputType="number"
                    android:layout_gravity="center"
                    android:selectAllOnFocus="true"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:background="@null"
                    android:layout_marginBottom="8dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bleu_clair_alcyons_transparent"
                    android:layout_marginHorizontal="14dp" />

            </LinearLayout>

            <!-- Bouton valider stock -->
            <LinearLayout
                android:id="@+id/np_valider_stock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingVertical="12dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/ic_check_circle"
                    android:backgroundTint="@color/bleu_clair_alcyons"
                    android:contentDescription="@null" />

            </LinearLayout>

            <!-- ═══════════════════════════════
                 ZONE DOTATION (gone par défaut)
            ═══════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutdotation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Séparateur section -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/bleu_fonce_alcyons"
                    android:layout_marginBottom="14dp" />

                <!-- Labels Besoin / Demandé -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:text="Besoin"
                        android:gravity="center"
                        android:alpha="0.7" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="13sp"
                        android:textColor="@color/vert"
                        android:text="Demandé"
                        android:gravity="center" />

                </LinearLayout>

                <!-- Valeurs Besoin / Demandé -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/np_qteBesoin"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="22sp"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:text=""
                        android:gravity="center"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/np_qteDemande"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="22sp"
                        android:text=""
                        android:textColor="@color/vert"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:inputType="number"
                        android:selectAllOnFocus="true"
                        android:background="@null" />

                </LinearLayout>

                <!-- Séparateur fin -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bleu_clair_alcyons_transparent"
                    android:layout_marginHorizontal="14dp" />

                <!-- Bouton valider dotation -->
                <LinearLayout
                    android:id="@+id/np_valider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="12dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/ic_check_circle"
                        android:backgroundTint="@color/vert"
                        android:contentDescription="@null" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>