<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="6dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#F0F4FF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- ═══════════════════════════════
                 BARRE STATUT (gauche)
            ═══════════════════════════════ -->
            <ImageView
                android:id="@+id/barreStatutDotation"
                android:layout_width="6dp"
                android:layout_height="match_parent"
                android:contentDescription="@null" />

            <!-- ═══════════════════════════════
                 INFOS : intitulé + statut
            ═══════════════════════════════ -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="12dp">

                <TextView
                    android:id="@+id/intituleDotation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:layout_marginBottom="6dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bleu_clair_alcyons_transparent"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/statutDotation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="12sp"
                    android:alpha="0.7" />

            </LinearLayout>

            <!-- ═══════════════════════════════
                 COLONNE QUANTITÉS
            ═══════════════════════════════ -->
            <LinearLayout
                android:id="@+id/linearQuantite"
                android:layout_width="64dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@color/bleu_fonce_alcyons">

                <!-- Quantité courante -->
                <TextView
                    android:id="@+id/nbProduitDotation"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text=""
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Séparateur entre les deux quantités -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#33FFFFFF" />

                <!-- Quantité totale -->
                <TextView
                    android:id="@+id/nbProduitDotationTotal"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text=""
                    android:gravity="center"
                    android:textColor="#BBDEFB"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>