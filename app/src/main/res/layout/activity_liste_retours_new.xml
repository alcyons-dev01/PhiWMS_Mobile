<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context="fr.alcyons.phimr4.ReceptionPUI.ServiceReceptionPuiActivity">

    <RelativeLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">


        <LinearLayout
            android:id="@+id/barreDeTitre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:background="@color/bleu_fonce_alcyons"
            android:orientation="horizontal"
            android:weightSum="4">

            <LinearLayout
                android:id="@+id/triListe"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@color/bleu_clair_alcyons"
                android:visibility="gone">

                <Spinner
                    android:id="@+id/optionTri"
                    android:background="@drawable/ic_sort_white"
                    android:entries="@array/option_tri_retour"
                    android:layout_height="30dp"
                    android:layout_width="30dp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/nbElementInAdapter"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_centerHorizontal="true"
                android:text="30"
                android:paddingStart="10dp"
                android:textColor="@color/bleu_clair_alcyons"
                android:textSize="24dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/titre"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_centerHorizontal="true"
                android:text=""
                android:layout_gravity="center_vertical"
                android:layout_weight="3"
                android:textColor="#FFFFFF"
                android:textSize="24dp"
                android:paddingStart="10dp"
                android:textStyle="bold" />



        </LinearLayout>

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefreshLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/barreDeTitre"
            android:layout_weight="7.5"
            android:orientation="vertical"
            android:paddingLeft="10dp"
            android:paddingRight="10dp">

            <ListView
                android:id="@+id/listeView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:descendantFocusability="afterDescendants">

            </ListView>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </RelativeLayout>
</RelativeLayout>
