<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header : Désignation + Référence -->
        <LinearLayout
            android:id="@+id/zoneDesignation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bleu_fonce_alcyons"
            android:padding="12dp">

            <TextView
                android:id="@+id/designationProduit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Designation"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/referenceProduit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Reference"
                android:textColor="#AAAAFF"
                android:textSize="13sp"/>

        </LinearLayout>

        <!-- Corps -->
        <LinearLayout
            android:id="@+id/LinearInfoVerrou"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F0F4FF"
            android:padding="10dp">

            <!-- Colis -->
            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bleu_fonce_alcyons">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@drawable/ic_colis"
                        android:backgroundTint="#FFFFFF"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/colis"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="@color/rouge"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:text="100"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Séparateur vertical -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/bleu_clair_alcyons_transparent"
                android:layout_marginEnd="8dp"/>

            <!-- Lot + Exp + Série -->
            <LinearLayout
                android:id="@+id/zoneInfoLot"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Lot -->
                <LinearLayout
                    android:id="@+id/layoutNumLot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lot"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="12sp"
                        android:alpha="0.6"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="8dp"/>

                    <EditText
                        android:id="@+id/numLot"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="text"
                        android:text="XXXX"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="@android:color/transparent"
                        android:padding="0dp"/>

                </LinearLayout>

                <!-- Séparateur -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bleu_clair_alcyons_transparent"
                    android:layout_marginBottom="6dp"/>

                <!-- Exp -->
                <LinearLayout
                    android:id="@+id/layoutDateExp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Exp"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="12sp"
                        android:alpha="0.6"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/datePeremption"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text=""
                        android:textColor="@color/rouge"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Séparateur -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bleu_clair_alcyons_transparent"
                    android:layout_marginBottom="6dp"/>

                <!-- Série -->
                <LinearLayout
                    android:id="@+id/layoutNumSerie"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="visible">

                    <TextView
                        android:id="@+id/textviewSerie"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Série"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="12sp"
                        android:alpha="0.6"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="8dp"/>

                    <EditText
                        android:id="@+id/numeroSerie"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:inputType="text"
                        android:text="XXXX"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:background="@android:color/transparent"
                        android:padding="0dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Séparateur vertical -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/bleu_clair_alcyons_transparent"
                android:layout_marginHorizontal="8dp"/>

            <!-- Quantité + Statut -->
            <androidx.cardview.widget.CardView
                android:id="@+id/layoutQuantite"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/rouge">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="10dp">

                    <TextView
                        android:id="@+id/qte_par_lot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="5"
                        android:textSize="18sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/statutLigne"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:textColor="#FFCCCC"
                        android:textSize="10sp"
                        android:text="@string/verrouPharmaciePreparee"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>