<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- ═══════════════════════════════
         HEADER : nom demande
    ═══════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layout1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bleu_fonce_alcyons"
        android:paddingHorizontal="14dp"
        android:paddingVertical="14dp">

        <TextView
            android:id="@+id/nomDemande"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp" />

    </LinearLayout>

    <!-- Séparateur accent -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/bleu_clair_alcyons" />

    <!-- ═══════════════════════════════
         BOUTON CLÔTURER AVANT LE
    ═══════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutBoutonEnvoyer"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@drawable/background_plein_vert_radius"
        android:layout_marginHorizontal="8dp"
        android:layout_marginVertical="8dp"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp">

        <TextView
            android:id="@+id/textEnvoi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="À clôturer avant le : "
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/dateEnvoiListe"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/layoutValider"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center">

            <ImageView
                android:id="@+id/iconEnvoi"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/ic_send_black"
                android:backgroundTint="#FFFFFF"
                android:contentDescription="@null" />

        </LinearLayout>

    </LinearLayout>

    <!-- ═══════════════════════════════
         RÉSUMÉ : nb références
    ═══════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/resumerDemande"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="4dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFF3E0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp">

            <TextView
                android:id="@+id/nbElementCommander"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/orange"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/titre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=" Références commandées sur "
                android:textColor="@color/bleu_fonce_alcyons"
                android:textSize="14sp"
                android:layout_marginHorizontal="4dp" />

            <TextView
                android:id="@+id/nbElementTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/orange"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- ═══════════════════════════════
         BARRE DE RECHERCHE
    ═══════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/layoutRecherche"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        android:layout_marginVertical="4dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp">

            <ImageView
                android:id="@+id/iconRecherche"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/ic_search_black"
                android:backgroundTint="@color/bleu_clair_alcyons"
                android:contentDescription="@null" />

            <EditText
                android:id="@+id/searchBarDemande"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="text"
                android:maxLines="1"
                android:hint="Rechercher une référence"
                android:background="@null"
                android:textColor="@color/bleu_fonce_alcyons"
                android:textColorHint="#90A4AE"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/removeSearchDemande"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/ic_croix_noir"
                android:backgroundTint="@color/bleu_clair_alcyons"
                android:visibility="gone"
                android:contentDescription="@null" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- ═══════════════════════════════
         LISTE
    ═══════════════════════════════ -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="4dp">

        <ListView
            android:id="@+id/listeView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:descendantFocusability="beforeDescendants"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>