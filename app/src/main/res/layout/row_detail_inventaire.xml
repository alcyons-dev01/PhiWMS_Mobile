<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">


        <LinearLayout
            android:id="@+id/layoutPrincipal_LL"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/background_cadre_bleu"
            android:layout_margin="5dp"
            android:padding="5dp"
            android:layout_weight="7">

            <LinearLayout
                android:id="@+id/layoutAjoutManuelle"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/imageStatutSaisie_IV"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/ic_edit_black"
                    android:backgroundTint="@color/bleu_clair_alcyons"/>
            </LinearLayout>

            <ImageView
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/bleu_clair_alcyons"/>

            <LinearLayout
                android:id="@+id/layoutDetail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="5"
                android:paddingHorizontal="5dp"
                android:orientation="vertical"
                android:background="@android:color/transparent">

                <TextView
                    android:id="@+id/nomProduit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Designation produit"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textColor="#000000"
                    android:textSize="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <TextView
                        android:id="@+id/refProduit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="ref "
                        android:textColor="#000000"
                        android:textSize="14dp"/>

                    <TextView
                        android:id="@+id/fournisseurProduit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:text="fournisseur"
                        android:textColor="#000000"
                        android:textSize="14dp"/>


                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBarReference_PB"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="5dp"
                    android:layout_gravity="center"
                    android:background="@drawable/background_empty_radius"
                    android:backgroundTint="@color/bleu_clair_alcyons_transparent"
                    android:progressDrawable="@drawable/progress_bar_background"/>

            </LinearLayout>

            <ImageView
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/bleu_clair_alcyons"/>

            <TextView
                android:id="@+id/stockSaisie"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical|center"
                android:text="20000"
                android:textStyle="bold"
                android:textSize="16dp"
                android:textColor="@color/bleu_clair_alcyons"/>

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>