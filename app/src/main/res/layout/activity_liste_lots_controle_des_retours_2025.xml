<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingBottom="15dp">


    <LinearLayout
        android:id="@+id/barreDeTitre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:background="@color/bleu_fonce_alcyons"
        android:orientation="horizontal"
        android:weightSum="5">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="5"
            android:orientation="vertical">

            <TextView
                android:id="@+id/numeroRetour"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/nomDepot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text=""
                android:layout_marginLeft="5dp"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/lancerScan"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_gravity="right"
            android:background="@color/bleu_clair_alcyons">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ic_datamatrix"/>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/temp"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_below="@id/barreDeTitre"
        android:background="@color/bleu_fonce_alcyons"
        android:orientation="horizontal"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:weightSum="2"/>

    <LinearLayout
        android:id="@+id/firstRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/barreDeTitre"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:padding="5dp"
        android:weightSum="5.75"
        android:background="@drawable/background_detail_preparation_orange">

        <LinearLayout
            android:id="@+id/layoutColis"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.5"
            android:orientation="vertical"
            android:layout_gravity="center_vertical"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/colis"
                android:background="@drawable/ic_colis" />

            <TextView
                android:id="@+id/colis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/rouge2"
                android:textSize="14sp"
                android:text="" />


        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="4"
            android:orientation="vertical">

            <TextView
                android:id="@+id/designationProduit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="18dp"
                android:text=""
                android:textColor="@color/noir"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/referenceProduit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16dp"
                android:text=""
                android:textColor="@color/noir"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.25"
            android:orientation="vertical"
            android:weightSum="2">

            <TextView
                android:id="@+id/QteRetourner"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="right"
                android:layout_marginRight="10dp"
                android:text=""
                android:textColor="@color/orange2"
                android:textSize="18dp"
                android:textStyle="bold"/>


            <TextView
                android:id="@+id/qteDeclaree"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="right"
                android:text=""
                android:layout_marginRight="10dp"
                android:textColor="@android:color/black"
                android:textSize="18dp"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/liste_view_lot_retour_ligne"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_below="@id/firstRow"
        android:layout_above="@id/btnAjoutManuel"
        android:divider="@android:color/transparent"
        android:paddingTop="10dp"
        android:scrollbars="vertical"/>

    <Button
        android:id="@+id/btnAjoutManuel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ajoutez un lot"
        android:background="@drawable/background_plain_bleu_radius"
        android:backgroundTint="@color/bleu_clair_alcyons"
        android:layout_marginHorizontal="50dp"
        android:layout_marginBottom="10dp"
        android:layout_alignParentEnd="true"
        android:textColor="@color/blanc"
        android:textSize="18dp"
        android:textStyle="bold"
        android:layout_alignParentBottom="true"
        android:visibility="visible"/>

</RelativeLayout>