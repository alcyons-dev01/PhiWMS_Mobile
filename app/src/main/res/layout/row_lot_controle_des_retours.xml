<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:weightSum="2"
        android:background="@drawable/background_element_list_droit"
        android:layout_margin="5dp">


        <LinearLayout
            android:id="@+id/layoutZoneEmplacement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <TextView
                android:id="@+id/TextViewZone"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Zone"
                android:gravity="center"/>

            <TextView
                android:id="@+id/TextViewEmplacement"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Emplacement"/>

        </LinearLayout>

        <ImageView
            android:id="@+id/SeparationZoneEmplacement"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/bleu_clair_alcyons"/>

        <LinearLayout
            android:id="@+id/general"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:weightSum="4">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textViewS"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Série : " />


                    <TextView
                        android:id="@+id/numSerie"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="NumSerie"
                        android:textColor="@android:color/black"
                        android:textSize="15dp"/>

                </LinearLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/textViewL"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lot :  " />


                    <TextView
                        android:id="@+id/numLot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="NumLot"
                        android:textColor="@android:color/holo_blue_light"
                        android:textSize="15sp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Exp :  "/>

                    <TextView
                        android:id="@+id/datePeremption"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="datePeremption"
                        android:textColor="@android:color/holo_red_light"
                        android:textSize="15dp" />

                </LinearLayout>




            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:weightSum="2">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:text="Stock"
                        android:gravity="center"/>

                    <ImageView
                        android:id="@+id/imageView3"
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginLeft="10dp"
                        android:layout_marginRight="10dp"
                        android:background="@color/bleu_clair_alcyons" />


                    <TextView
                        android:id="@+id/qteActuelle"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:text="qteStock"
                        android:gravity="center"
                        android:textColor="@android:color/holo_red_light" />

                </LinearLayout>


            </LinearLayout>

            <ImageView
                android:layout_width="2dp"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:layout_margin="5dp"
                android:background="@android:color/darker_gray" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_weight="1">

                <TextView
                    android:id="@+id/qteSaisie"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:textColor="@android:color/black"
                    android:textSize="20sp"
                    android:layout_gravity="center"
                    android:gravity="center"/>

            </LinearLayout>

        </LinearLayout>


    </LinearLayout>



</RelativeLayout>