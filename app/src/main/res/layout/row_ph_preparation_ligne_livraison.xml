<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="6dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#F0F4FF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- ═══════════════════════════════
                 COLONNE GAUCHE : infos produit
            ═══════════════════════════════ -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3.75"
                android:orientation="vertical">

                <!-- Header : nb colis + référence -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/bleu_fonce_alcyons"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/ic_colis"
                        android:backgroundTint="#FFFFFF"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/nbColis"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/rouge"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:id="@+id/referenceProduit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text=""
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Séparateur accent -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/bleu_clair_alcyons" />

                <!-- Désignation -->
                <TextView
                    android:id="@+id/designationProduit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="13sp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:maxLines="2"
                    android:ellipsize="end" />

            </LinearLayout>

            <!-- ═══════════════════════════════
                 SÉPARATEUR VERTICAL
            ═══════════════════════════════ -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/bleu_clair_alcyons" />

            <!-- ═══════════════════════════════
                 COLONNE DROITE : qté + actions
            ═══════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutValidation"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.25"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="#F0F4FF">

                <!-- Quantité livrée -->
                <LinearLayout
                    android:id="@+id/layout_qteLivrer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_gravity="center_vertical"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/qte_livree"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:gravity="center"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Séparateur vertical fin -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/bleu_clair_alcyons_transparent" />

                <!-- Boutons Accepter / Refuser -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/Accepter"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_check"
                        android:backgroundTint="@color/vert"
                        android:layout_marginBottom="6dp"
                        android:contentDescription="@null" />

                    <ImageView
                        android:id="@+id/Refuser"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_clear"
                        android:backgroundTint="@color/rouge"
                        android:visibility="gone"
                        android:contentDescription="@null" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>