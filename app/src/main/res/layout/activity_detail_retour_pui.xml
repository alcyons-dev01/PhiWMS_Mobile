<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <RelativeLayout
        android:id="@+id/frameLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white">

        <!-- Barre de titre -->
        <LinearLayout
            android:id="@+id/barreDeTitre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:background="@color/bleu_fonce_alcyons"
            android:orientation="horizontal"
            android:weightSum="2"
            android:padding="8dp">

            <TextView
                android:id="@+id/numero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="numéro"
                android:textColor="@android:color/white" />

        </LinearLayout>

        <!-- Detail container flottant -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/detailContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:visibility="gone"
            android:elevation="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@android:color/transparent"/>

        <!-- Contenu scrollable — contraint entre la barre de titre et le bouton -->
        <LinearLayout
            android:id="@+id/layoutCorpsRetourPui"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/barreDeTitre"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="4dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Ligne SCANNER + CHERCHER côte à côte -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:background="@color/bleu_fonce_alcyons">

                        <!-- CHERCHER — moitié gauche -->
                        <LinearLayout
                            android:id="@+id/lancerRecherhe"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center_vertical"
                                android:src="@drawable/ic_search"
                                android:layout_marginEnd="8dp"
                                app:tint="#FFFFFF"/>

                            <TextView
                                android:id="@+id/textChercher_TV"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="CHERCHER"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:maxLines="1"
                                android:ellipsize="end"/>

                            <EditText
                                android:id="@+id/searchInput_ET"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Rechercher..."
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:background="@android:color/transparent"
                                android:inputType="text"
                                android:imeOptions="actionSearch"
                                android:visibility="gone"/>

                            <ImageView
                                android:id="@+id/effacerRecherche_IV"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_clear"
                                android:layout_marginEnd="4dp"
                                app:tint="#FFFFFF"
                                android:visibility="gone"/>

                            <ImageView
                                android:id="@+id/chevronRecherche"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/chevron_down_24dp"
                                app:tint="#FFFFFF"
                                android:visibility="gone"/>

                        </LinearLayout>

                        <!-- Séparateur vertical -->
                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="#33FFFFFF"/>

                        <!-- SCANNER — moitié droite -->
                        <LinearLayout
                            android:id="@+id/lancerScan"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp">

                            <ImageView
                                android:id="@+id/iconLancerScan"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center_vertical"
                                android:src="@drawable/ic_datamatrix"
                                android:layout_marginEnd="8dp"
                                app:tint="#FFFFFF"/>

                            <TextView
                                android:id="@+id/textLancerScan"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="SCANNER"
                                android:textColor="#FFFFFF"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.05"
                                android:maxLines="1"
                                android:ellipsize="end"/>

                            <ImageView
                                android:id="@+id/chevronScan"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/chevron_down_24dp"
                                app:tint="#FFFFFF"
                                android:visibility="gone"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Séparateur entre header et containers -->
                    <View
                        android:id="@+id/separateurScan"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:visibility="gone"/>

                    <!-- Container scanner — s'ouvre sous la barre -->
                    <androidx.fragment.app.FragmentContainerView
                        android:id="@+id/scannerContainer"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:visibility="gone"/>

                    <View
                        android:id="@+id/separateurRecherche"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:visibility="gone"/>

                    <!-- Container recherche — s'ouvre sous la barre -->
                    <androidx.fragment.app.FragmentContainerView
                        android:id="@+id/rechercheContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARTE À RETOURNER PUI -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/aRetournerPUI_LL"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@color/rouge">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="À RETOURNER"
                            android:layout_weight="1"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>

                        <TextView
                            android:id="@+id/nbReferenceARetournerPUI_TV"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:background="#44FFFFFF"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="2dp"
                            android:layout_marginEnd="10dp"/>

                        <ImageView
                            android:id="@+id/chevronARetournerPUI"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/chevron_down_24dp"
                            app:tint="#FFFFFF"/>

                    </LinearLayout>

                    <View
                        android:id="@+id/separateurARetournerPUI"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:visibility="gone"/>

                    <androidx.fragment.app.FragmentContainerView
                        android:id="@+id/referenceARetournerPUIContainer"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:visibility="gone"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- CARTE RETOURNE -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/retournerPUI_LL"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@color/vert">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="RETOURNÉ"
                            android:layout_weight="1"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>

                        <TextView
                            android:id="@+id/nbReferenceRetournerPUI_TV"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:background="#44FFFFFF"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="2dp"
                            android:layout_marginEnd="10dp"/>

                        <ImageView
                            android:id="@+id/chevronRetournerPUI"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/chevron_down_24dp"
                            app:tint="#FFFFFF"/>

                    </LinearLayout>

                    <View
                        android:id="@+id/separateurRetournerPUI"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:visibility="gone"/>

                    <androidx.fragment.app.FragmentContainerView
                        android:id="@+id/referenceRetournerPUIContainer"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:visibility="gone"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>


        <!-- Bouton toujours visible en bas -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/boutonAction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/layoutCorpsRetourPui"
            android:text="Confirmer le retour"
            android:textColor="@color/blanc"
            android:layout_margin="10dp"
            android:background="@drawable/background_plein_vert_radius"
            android:visibility="visible"/>

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
