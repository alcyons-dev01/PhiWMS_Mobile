<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/topLayout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:keepScreenOn="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="3"
        android:gravity="center">

        <fr.alcyons.phimr4.BarcodeSearch.camera.CameraSourcePreview
            android:id="@+id/preview"
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:foregroundGravity="center_horizontal">

            <fr.alcyons.phimr4.BarcodeSearch.camera.GraphicOverlay
                android:id="@+id/graphicOverlay"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" />

        </fr.alcyons.phimr4.BarcodeSearch.camera.CameraSourcePreview>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="190dp"
        android:background="@color/noirtransparent"
        android:orientation="vertical"
        android:layout_alignParentBottom="true">

        <LinearLayout
            android:id="@+id/linearRayonnage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="60dp"
                android:weightSum="1">

                <TextView
                    android:gravity="center"
                    android:id="@+id/rayonnageSelect"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textSize="20dp"
                    android:textStyle="bold"
                    android:textColor="@color/blanc"/>

                <ImageView
                    android:id="@+id/effacerEmplacement"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:background="@drawable/ic_clear" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/LinearTextProduitReceptionScanne"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:orientation="vertical">

                <ListView
                    android:id="@+id/listLotSerieScan"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutProduitPreparationADH"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:visibility="gone">

                <TextView
                    android:id="@+id/DesignationProduitScannee"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/blanc"
                    android:textSize="18dp"/>

                <EditText
                    android:id="@+id/quantiteProduitScannee"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:inputType="number"
                    android:textColor="@color/blanc"
                    android:textColorLink="@color/blanc"
                    android:visibility="gone"/>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutlogoscan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="60dp"
            android:weightSum="3"
            android:visibility="visible">

            <LinearLayout
                android:id="@+id/layout_image_datamatrix"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center"
                android:gravity="center">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/ic_datamatrix"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_image_document"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center"
                android:gravity="center">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/ic_doc"
                    android:backgroundTint="@color/blanc"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_image_codebarre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center"
                android:gravity="center">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/ic_barcode"
                    android:backgroundTint="@color/blanc"/>

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/noir"
            android:text="Scanner un datamatrix d'un produit"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="20sp" />

    </LinearLayout>

    <TextView
        android:id="@+id/compteurScan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/banner"
        android:background="@color/grey_color_fonce_50Pourcent"
        android:text=""
        android:textColor="@color/blanc"
        android:textAlignment="center"
        android:textSize="20sp"
        tools:ignore="NotSibling" />

    <TextView
        android:id="@+id/messageFranceMVO"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/grey_color_fonce_50Pourcent"
        android:layout_below="@+id/compteurScan"
        android:text=""
        android:textColor="@color/blanc"
        android:textAlignment="center"
        android:textSize="20sp"
        android:visibility="gone"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true">

        <TextView
            android:id="@+id/compteurReliquat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/grey_color_fonce_50Pourcent"
            android:text=""
            android:textColor="@color/blanc"
            android:textAlignment="center"
            android:textSize="20sp"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/grey_color_fonce_50Pourcent"
            android:text=""
            android:textColor="@color/blanc"
            android:textAlignment="center"
            android:textSize="20sp" />

    </LinearLayout>

    <EditText
        android:id="@+id/contenuCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignBottom="@+id/scannerMode"
        android:layout_alignEnd="@+id/scannerMode"
        android:layout_alignRight="@+id/scannerMode"
        android:inputType="textFilter|textMultiLine"
        android:textColor="@android:color/white"
        android:visibility="invisible"
        tools:ignore="NotSibling" />

    <com.github.clans.fab.FloatingActionButton
        android:id="@+id/boutonFermeture"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignEnd="@+id/floatingMenu"
        android:layout_alignRight="@+id/floatingMenu"
        android:layout_below="@+id/banner"
        android:src="@drawable/ic_clear"
        app:fab_size="normal"
        android:visibility="gone"
        tools:ignore="NotSibling" />

    <com.github.clans.fab.FloatingActionMenu
        android:id="@+id/floatingMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_marginBottom="55dp"
        android:layout_marginEnd="16dp"
        app:menu_icon="@drawable/ic_settings">

        <com.github.clans.fab.FloatingActionButton
            android:id="@+id/flash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_flash"
            app:fabSize="mini"
            app:fab_colorNormal="@android:color/darker_gray"
            app:fab_colorPressed="@android:color/darker_gray"
            app:fab_colorRipple="@android:color/darker_gray"
            app:fab_label="Flash" />

        <com.github.clans.fab.FloatingActionButton
            android:id="@+id/changeMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_datamatrix"
            app:fabSize="mini"
            app:fab_colorNormal="@android:color/black"
            app:fab_colorPressed="@android:color/black"
            app:fab_colorRipple="@android:color/black"
            app:fab_label="Datamatrix inversé" />

        <com.github.clans.fab.FloatingActionButton
            android:id="@+id/scannerMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_lecteur"
            app:fabSize="mini"
            app:fab_colorNormal="@android:color/holo_red_light"
            app:fab_colorPressed="@android:color/holo_red_light"
            app:fab_colorRipple="@android:color/holo_red_light"
            app:fab_label="Lecteur code-barre" />

        <com.github.clans.fab.FloatingActionButton
            android:id="@+id/clavierMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_keyboard"
            app:fabSize="mini"
            app:fab_colorNormal="@android:color/holo_orange_light"
            app:fab_colorPressed="@android:color/holo_orange_light"
            app:fab_colorRipple="@android:color/holo_orange_light"
            app:fab_label="Clavier" />

        <com.github.clans.fab.FloatingActionButton
            android:id="@+id/takePictureButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_photo_camera"
            app:fabSize="mini"
            app:fab_colorNormal="@color/bleu_clair_alcyons"
            app:fab_colorPressed="@color/bleu_clair_alcyons"
            app:fab_colorRipple="@color/bleu_clair_alcyons"
            app:fab_label="Prise de photo" />

        <com.github.clans.fab.FloatingActionButton
            android:id="@+id/versZebra"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/speaker_phone"
            app:fabSize="mini"
            app:fab_colorNormal="@color/vert3"
            app:fab_colorPressed="@color/vert3"
            app:fab_colorRipple="@color/vert3"
            app:fab_label="Zebra" />

    </com.github.clans.fab.FloatingActionMenu>


</RelativeLayout>
