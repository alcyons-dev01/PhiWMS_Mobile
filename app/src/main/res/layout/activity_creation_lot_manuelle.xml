<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white">


    <LinearLayout
        android:id="@+id/barreDeTitre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bleu_fonce_alcyons"
        android:orientation="vertical"
        android:weightSum="2">

        <TextView
            android:id="@+id/numPreparation"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:text=""
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="72dp"/>

        <TextView
            android:id="@+id/depotPreparation"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:gravity="left"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="72dp"
            android:textStyle="bold"
            android:text=""/>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutProduit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/barreDeTitre"
        android:orientation="vertical"
        android:layout_marginTop="15dp"
        android:layout_margin="5dp"
        android:background="@drawable/background_cadre_orange"
        android:padding="2dp">

        <TextView
            android:id="@+id/nomProduit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ProduitDesignation"
            android:textColor="@android:color/black"
            android:textSize="17sp"
            android:layout_marginRight="15dp"
            android:layout_marginLeft="5dp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/referenceProduit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ProduitReference"
                android:textColor="@android:color/black"
                android:textSize="15sp"
                android:layout_marginRight="15dp"
                android:layout_marginLeft="5dp" />

        </LinearLayout>



    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/layoutProduit">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:orientation="vertical"
            android:padding="10dp"
            android:background="@drawable/background_cadre_vert">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/vert"
                android:textColor="@color/blanc"
                android:textStyle="bold"
                android:textSize="16dp"
                android:gravity="center"
                android:padding="5dp"
                android:text="LOT AJOUTER"/>

            <LinearLayout
                android:id="@+id/zonePlacementLot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:weightSum="3"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginRight="15dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2.5"
                    android:orientation="vertical"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:text="Zone"
                            android:textColor="@color/bleu_clair_alcyons"
                            android:textStyle="bold"
                            android:layout_marginLeft="5dp"
                            android:textSize="24dp"/>

                        <TextView
                            android:id="@+id/zoneName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:textSize="24dp"
                            android:textColor="@android:color/black"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:orientation="horizontal"
                        android:layout_weight="1">

                        <TextView
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:text="Place"
                            android:textColor="@color/bleu_clair_alcyons"
                            android:textStyle="bold"
                            android:textSize="24dp" />

                        <TextView
                            android:id="@+id/nomEmplacement"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:inputType="text"
                            android:textSize="24dp"
                            android:textColor="@android:color/black"
                            android:textStyle="bold"  />


                    </LinearLayout>


                </LinearLayout>

                <LinearLayout
                    android:id="@+id/linearDatamatrix1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:layout_weight="0.5"
                    android:orientation="vertical"
                    android:layout_gravity="center_vertical">

                    <ImageView
                        android:id="@+id/datamatrix1"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:clickable="true"
                        android:contentDescription="@string/datamatrix"
                        android:background="@drawable/ic_datamatrix"
                        android:backgroundTint="@color/bleu_clair_alcyons" />

                </LinearLayout>


            </LinearLayout>

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_gravity="center_vertical"
                android:background="@color/vert"
                android:layout_marginTop="10dp"
                android:layout_marginRight="15dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:weightSum="3"
                android:layout_marginRight="15dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2.5"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/layoutNumSerie"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        android:padding="5dp"
                        android:weightSum="4">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Serie"
                                android:textSize="14sp"
                                android:gravity="left"
                                android:textColor="@color/noir"
                                android:layout_gravity="center"/>

                        <TextView
                            android:id="@+id/numSerie"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            android:layout_gravity="center"
                            android:textSize="16dp"
                            android:hint="Ajouter un numéro de série"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        android:padding="5dp"
                        android:weightSum="4">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Lot"
                            android:textSize="14sp"
                            android:gravity="left"
                            android:textColor="@color/noir"
                            android:layout_gravity="center"/>

                        <TextView
                            android:id="@+id/numLot"
                            android:layout_width="0dp"
                            android:layout_weight="3"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:textSize="16dp"
                            android:hint="Ajouter un numéro Lot"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp"
                        android:padding="5dp"
                        android:weightSum="4">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Exp."
                            android:textSize="14sp"
                            android:gravity="left"
                            android:textColor="@color/noir"
                            android:layout_gravity="center"/>

                        <include
                            layout="@layout/layout_selecteur_date"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="3"
                            android:layout_gravity="center"/>

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:layout_weight="0.5"
                    android:orientation="vertical"
                    android:layout_gravity="center_vertical">

                    <ImageView
                        android:id="@+id/datamatrix2"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:clickable="true"
                        android:contentDescription="@string/datamatrix"
                        android:background="@drawable/ic_datamatrix"
                        android:backgroundTint="@color/bleu_clair_alcyons" />

                </LinearLayout>


            </LinearLayout>

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_gravity="center_vertical"
                android:background="@color/vert"
                android:layout_marginTop="10dp"
                android:layout_marginRight="15dp"/>

            <LinearLayout
                android:id="@+id/layout_gestion_conditionnement_LL"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/background_cadre_bleu"
                android:layout_marginHorizontal="5dp"
                android:layout_marginTop="10dp"
                android:weightSum="2">

                <LinearLayout
                    android:id="@+id/layoutCartonFermer_LL"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:backgroundTint="@color/vertTransparent"
                    android:background="@drawable/background_empty_radius_left"
                    android:layout_margin="1dp">

                    <TextView
                        android:id="@+id/textCartonFermer_TV"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Carton fermé"
                        android:textSize="14dp"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:textColor="@color/noir"
                        android:paddingVertical="5dp"
                        android:paddingHorizontal="10dp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/bleu_fonce_alcyons"/>

                <LinearLayout
                    android:id="@+id/layoutCartonOuvert_LL"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/background_empty_radius_right"
                    android:layout_margin="1dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Carton ouvert (x1)"
                        android:textSize="14dp"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:textColor="@color/noir"
                        android:paddingVertical="5dp"
                        android:paddingHorizontal="10dp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:padding="5dp"
                android:weightSum="5">

                <LinearLayout
                    android:id="@+id/layoutMoins_LL"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_gravity="center">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/minus_circle"
                        android:layout_gravity="center"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/bleu_fonce_alcyons"/>

                <EditText
                    android:id="@+id/qteActuelle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textSize="24dp"
                    android:gravity="center"
                    android:text="45"
                    android:textColor="@color/noir"
                    android:inputType="number"
                    android:layout_weight="3"/>


                <ImageView
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/bleu_fonce_alcyons"/>

                <LinearLayout
                    android:id="@+id/layoutPlus_LL"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_gravity="center">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/ic_plus"
                        android:layout_gravity="center" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <LinearLayout
        android:id="@+id/validationScan"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentTop="true"
        android:layout_marginTop="5dp"
        android:layout_alignParentEnd="true"
        android:layout_marginRight="15dp"
        android:gravity="right"
        android:visibility="gone">

        <ImageView
            android:id="@+id/imageValidation"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/ic_check_circle"/>

    </LinearLayout>

</RelativeLayout>
