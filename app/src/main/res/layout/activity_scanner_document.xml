<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="fr.alcyons.phimr4.BarcodeSearch.ScannerSearchOnlyActivity">


    <LinearLayout
        android:id="@+id/linearScanManuel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:weightSum="3">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2">

            <LinearLayout
                android:id="@+id/layoutImageScan"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/imageGriseScanManuel"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="@color/grey_color"/>

                <ImageView
                    android:id="@+id/imageScanPreparation"
                    android:layout_width="64dp"
                    android:layout_height="72dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/phitagdocprep"
                    android:visibility="gone"/>

                <ImageView
                    android:id="@+id/imageScanReception"
                    android:layout_width="64dp"
                    android:layout_height="72dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/phitagdoccom"
                    android:visibility="gone"/>

            </LinearLayout>


            <TextView
                android:id="@+id/designationProduit_Scan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/noir"
                android:text="Document"
                android:textSize="20dp"
                android:textStyle="bold"
                android:layout_below="@+id/layoutImageScan"/>

            <TextView
                android:id="@+id/textManuelScan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:textColor="@color/noir"
                android:textSize="18dp"
                android:layout_below="@+id/designationProduit_Scan"/>

            <EditText
                android:id="@+id/contenuCodeManuel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/textManuelScan"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="30dp"
                android:background="@color/blanc"
                android:gravity="center"
                android:imeOptions="actionDone"
                android:textColor="@android:color/black" />


            <TextView
                android:layout_below="@+id/contenuCodeManuel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="OU"
                android:textColor="@color/bleu_clair_alcyons"
                android:textStyle="bold"
                android:textSize="28dp"/>


        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <Button
                android:id="@+id/boutonFermetureManuel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sélection manuel"
                android:textColor="@color/blanc"
                android:layout_marginTop="40dp"
                android:layout_marginRight="20dp"
                android:layout_marginLeft="20dp"
                android:background="@color/bleu_clair_alcyons"/>


        </LinearLayout>

    </LinearLayout>

</RelativeLayout>





