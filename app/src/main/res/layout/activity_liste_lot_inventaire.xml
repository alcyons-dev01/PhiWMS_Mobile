<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@android:color/white"
    android:paddingBottom="5dp">

    <RelativeLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:background="@android:color/white"
        tools:ignore="MissingConstraints">


        <LinearLayout
            android:id="@+id/barreDeTitre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:background="@color/bleu_fonce_alcyons"
            android:orientation="horizontal"
            android:weightSum="4">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="4"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/produitDesgination"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_marginLeft="5dp"/>

                <TextView
                    android:id="@+id/inventaireCourant"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_marginLeft="5dp"/>

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/temp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_below="@id/barreDeTitre"
            android:background="@color/bleu_fonce_alcyons"
            android:orientation="horizontal"
            android:weightSum="2"/>

        <LinearLayout
            android:id="@+id/lancerScan"
            android:layout_below="@id/barreDeTitre"
            android:layout_width="match_parent"
            android:layout_height="50sp"
            android:background="@drawable/background_empty_radius_top"
            android:backgroundTint="@color/rouge"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:weightSum="4">

            <TextView
                android:id="@+id/textLancerScan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="SCANNER"
                android:layout_gravity="center"
                android:gravity="center_vertical"
                android:layout_weight="4"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:paddingStart="10dp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/iconLancerScan"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="10dp"
                android:layout_gravity="center_vertical"
                android:background="@drawable/ic_datamatrix"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView xmlns:android="http://schemas.android.com/apk/res/android"
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:nestedScrollingEnabled="false"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="65dp"
            android:background="@drawable/background_empty_radius_top"
            android:padding="5dp"
            android:layout_below="@+id/lancerScan"/>

        <Button
            android:id="@+id/btnAjoutManuel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ajoutez un lot"
            android:background="@drawable/background_plein_bleu_radius"
            android:backgroundTint="@color/bleu_clair_alcyons"
            android:layout_marginHorizontal="50dp"
            android:layout_marginBottom="10dp"
            android:layout_alignParentEnd="true"
            android:textColor="@color/blanc"
            android:textSize="18dp"
            android:textStyle="bold"
            android:layout_alignParentBottom="true"/>

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>