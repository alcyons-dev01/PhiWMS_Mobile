<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="?android:attr/activatedBackgroundIndicator">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/background_element_liste_radius"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="10dp"
        android:weightSum="5">

        <TextView
            android:id="@+id/nomZone"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text=""
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:paddingLeft="10dp"/>

        <TextView
            android:id="@+id/nomEmplacement"
            android:layout_width="0px"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text=""
            android:textSize="12sp" />

        <ImageView
            android:layout_width="2dp"
            android:layout_height="match_parent"
            android:background="@color/bleu_clair_alcyons"
            android:contentDescription="@string/separateur" />

        <LinearLayout
            android:id="@+id/zoneDroite"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/qteRetournee"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@android:color/holo_red_light" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>