<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- ═══════════════════════════════
         BARRE DE TITRE
    ═══════════════════════════════ -->
    <LinearLayout
        android:id="@+id/barreDeTitre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bleu_fonce_alcyons"
        android:gravity="center"
        android:paddingVertical="14dp">

        <TextView
            android:id="@+id/titre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dotation Globale"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Séparateur accent -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="@color/bleu_clair_alcyons" />

    <!-- ═══════════════════════════════
         BOUTON SCANNER
    ═══════════════════════════════ -->
    <LinearLayout
        android:id="@+id/lancerScan"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="8dp"
        android:layout_marginVertical="10dp"
        android:background="@drawable/background_plein_rouge_radius"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/textLancerScan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SCANNER"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/iconLancerScan"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/ic_datamatrix"
            android:backgroundTint="#FFFFFF"
            android:contentDescription="@null" />

    </LinearLayout>

    <!-- ═══════════════════════════════
         LISTE (visible après scan)
    ═══════════════════════════════ -->
    <LinearLayout
        android:id="@+id/sousTitreDate"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:visibility="gone">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefreshLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ListView
                android:id="@+id/listeView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:descendantFocusability="afterDescendants"
                android:divider="@android:color/transparent"
                android:dividerHeight="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:clipToPadding="false" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

    <!-- ═══════════════════════════════
         ZONE SYNCHRONISATION
    ═══════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutSyncronisationPreparations"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <!-- Enregistrement des préparations -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Enregistrement des préparations"
                        android:textSize="14sp"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/compteurEnregistrementCourant"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:text=" / " />

                    <TextView
                        android:id="@+id/nbTotalPreparations"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textStyle="bold" />

                </LinearLayout>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:indeterminateTint="@color/bleu_clair_alcyons"
                    android:indeterminate="true" />

                <!-- Séparateur -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bleu_clair_alcyons_transparent"
                    android:layout_marginBottom="14dp" />

                <!-- Enregistrement des lignes -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Enregistrement des lignes"
                        android:textSize="14sp"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/compteurEnregistrementPLCourant"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:text=" / " />

                    <TextView
                        android:id="@+id/nbTotalPreparationsLignes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textStyle="bold" />

                </LinearLayout>

                <ProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminateTint="@color/bleu_clair_alcyons"
                    android:indeterminate="true" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</LinearLayout>