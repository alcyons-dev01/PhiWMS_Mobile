<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="fr.alcyons.phiwms_mobile.ParametresServeur.ServiceParametresServeurActivity">


    <LinearLayout
        android:id="@+id/parametreUtilisateur"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="10dp">

        <LinearLayout
            android:id="@+id/afficherInformationAuthentificationForte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/bleu_fonce_alcyons"
            android:gravity="center"
            android:weightSum="1">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Préférences utilisateur"
                android:textColor="@android:color/white"
                android:fontFamily="sans-serif"
                android:textSize="20sp"
                android:gravity="center"
                android:padding="5dp"
                android:layout_gravity="center"/>

            <ImageView
                android:id="@+id/informationAuthentificationForte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ic_info_outline"
                android:layout_gravity="center"
                android:layout_marginRight="10dp"/>


        </LinearLayout>

        <Switch
            android:id="@+id/authentificationForte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Authentification Forte"
            android:textColor="@android:color/black"
            android:fontFamily="sans-serif"
            android:textSize="18sp"
            android:layout_margin="10dp"
            android:theme="@style/SCBSwitch"/>

        <Switch
            android:id="@+id/connexionDirecte"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connexion directe"
            android:textColor="@android:color/black"
            android:fontFamily="sans-serif"
            android:textSize="18sp"
            android:layout_margin="10dp"
            android:theme="@style/SCBSwitch"/>


        <Switch
            android:id="@+id/modeTrace"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trace Mode"
            android:textColor="@android:color/black"
            android:fontFamily="sans-serif"
            android:textSize="18sp"
            android:layout_margin="10dp"
            android:theme="@style/SCBSwitch"
            android:visibility="gone"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/bleu_fonce_alcyons"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:text="Sélection des tris par défaut"
            android:gravity="center"
            android:textColor="@color/noir"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/bleu_fonce_alcyons"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Préparation ligne triée par "
                android:textSize="15dp"
                android:textColor="@color/noir"/>

            <Spinner
                android:id="@+id/choixTriListePreparation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:entries="@array/option_tri_preparation"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.75"
                android:text="Réception triée par "
                android:textSize="15dp"
                android:textColor="@color/noir"/>

            <Spinner
                android:id="@+id/choixTriListeRéception"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.25"
                android:entries="@array/option_tri_reception"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.75"
                android:text="Reliquat triée par "
                android:textSize="15dp"
                android:textColor="@color/noir"/>

            <Spinner
                android:id="@+id/choixTriListeReliquat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.25"
                android:entries="@array/option_tri_reception_detail"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.75"
                android:text="Retour triée par "
                android:textSize="15dp"
                android:textColor="@color/noir"/>

            <Spinner
                android:id="@+id/choixTriListeRetour"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.25"
                android:entries="@array/option_tri_retour"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.75"
                android:text="Retour Ligne triée par "
                android:textSize="15dp"
                android:textColor="@color/noir"/>

            <Spinner
                android:id="@+id/choixTriListeRetourLigne"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.25"
                android:entries="@array/option_tri_retour_ligne"/>

        </LinearLayout>


        <Button
            android:id="@+id/jeuEssaiAlcyons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Créer un jeu d'essai ALCYONS"
            android:textSize="18sp"
            android:textColor="@color/noir"
            android:layout_margin="10dp"
            android:fontFamily="sans-serif"
            android:visibility="gone"/>

    </LinearLayout>

</RelativeLayout>
