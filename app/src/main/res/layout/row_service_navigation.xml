<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="@android:color/white"
    android:orientation="vertical">


    <LinearLayout
        android:id="@+id/principal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginRight="5dp"
        android:weightSum="5">

        <ImageView
            android:id="@+id/boutonInformation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_info"
            android:layout_gravity="center_horizontal|center_vertical"
            android:backgroundTint="@color/bleu_clair_alcyons"
            android:layout_marginLeft="5dp"
            android:layout_marginRight="5dp"
            android:visibility="gone"/>


        <ImageView
            android:id="@+id/barreIndicateur"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:background="@color/bleu_clair_alcyons"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:orientation="vertical">

            <TextView
                android:id="@+id/nomService"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:layout_marginLeft="5dp"
                android:layout_gravity="center"
                style="@style/sectiongras_style"/>

            <TextView
                android:id="@+id/descriptionService"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:layout_marginLeft="5dp"
                android:layout_gravity="center"
                style="@style/text1ligne_style"/>


        </LinearLayout>

        <TextView
            android:id="@+id/indicateurService"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="right|center_vertical"
            android:text=""
            android:textColor="@color/bleu_clair_alcyons"
            style="@style/titre_style"/>

    </LinearLayout>



    <ImageView
        android:id="@+id/listViewSeparation"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gris_clair"/>

</LinearLayout>