<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header : Titre -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bleu_fonce_alcyons"
            android:padding="8dp">

            <TextView
                android:id="@+id/titre"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Confirmation"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

            <ImageView
                android:id="@+id/fermerModale"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_clear"
                android:layout_gravity="center"/>

        </LinearLayout>

        <!-- Message -->
        <TextView
            android:id="@+id/textIdentification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ajouter l'identification suivante : "
            android:gravity="center"
            android:background="#F0F4FF"
            android:paddingVertical="24dp"
            android:paddingHorizontal="16dp"
            android:textColor="@color/bleu_fonce_alcyons"
            android:textSize="15sp"/>

        <!-- Séparateur -->
        <View
            android:id="@+id/separateur"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/bleu_clair_alcyons_transparent"/>

        <!-- Boutons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/bleu_fonce_alcyons"
            android:weightSum="2">

            <!-- Annuler -->
            <LinearLayout
                android:id="@+id/boutonCarton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="4dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_colis"
                    app:tint="@color/rouge"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/TitreCarton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Conditionnement"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"/>

            </LinearLayout>

            <!-- Séparateur vertical -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#33FFFFFF"/>

            <!-- Confirmer -->
            <LinearLayout
                android:id="@+id/boutonUnitaire"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="4dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/icon_produit"
                    app:tint="@color/vert"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/TitreUnitaire"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unitaire"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>