<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Contenu principal avec padding -->
        <LinearLayout
            android:id="@+id/layoutPrincipal_LL"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Désignation -->
            <TextView
                android:id="@+id/nomProduit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Designation produit longue sur plusieurs lignes si besoin"
                android:textStyle="bold"
                android:maxLines="3"
                android:ellipsize="end"
                android:textColor="@color/bleu_fonce_alcyons"
                android:textSize="15sp"
                android:layout_marginBottom="6dp"/>

            <!-- Séparateur -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/bleu_clair_alcyons_transparent"
                android:layout_marginBottom="6dp"/>

            <!-- Ligne 2 : Référence + Fournisseur -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/refProduit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="REF-001234"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="11sp"
                    android:alpha="0.7"/>

                <TextView
                    android:id="@+id/fournisseurProduit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="Fournisseur"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="11sp"
                    android:alpha="0.7"/>

            </LinearLayout>

            <!-- Séparateur -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/bleu_clair_alcyons_transparent"
                android:layout_marginBottom="6dp"/>

            <!-- Ligne 3 : Lot + Date péremption -->
            <LinearLayout
                android:id="@+id/InformationLot_LL"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lot"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="10sp"
                        android:alpha="0.6"/>

                    <TextView
                        android:id="@+id/lotProduit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LOT-2024-001"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutSerieNumero"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Série"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="10sp"
                        android:alpha="0.6"/>

                    <TextView
                        android:id="@+id/serieProduit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SERIE-2024-001"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Péremption"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="10sp"
                        android:alpha="0.6"/>

                    <TextView
                        android:id="@+id/peremptionProduit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12/2026"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- Bandeau quantité à préparer — EN DEHORS du padding, collé en bas -->
        <LinearLayout
            android:id="@+id/bandeauQteAPreparer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/rouge"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Quantité à préparer"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center_vertical"/>

            <TextView
                android:id="@+id/quantiteAPreparer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center_vertical"/>

        </LinearLayout>

        <!-- Bandeau quantité — EN DEHORS du padding, collé en bas -->
        <LinearLayout
            android:id="@+id/bandeauQtePreparer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/vert"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Quantité préparer"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center_vertical"/>

            <TextView
                android:id="@+id/quantitePreparer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center_vertical"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>