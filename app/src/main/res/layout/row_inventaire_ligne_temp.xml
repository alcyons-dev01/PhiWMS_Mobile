<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Arrière-plan : bouton supprimer -->
    <LinearLayout
        android:id="@+id/deleteLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/rouge"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:layout_marginTop="5dp">

        <ImageView
            android:id="@+id/btn_delete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_clear"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/blanc" />
    </LinearLayout>

    <!-- Contenu principal de l’item -->
    <RelativeLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:descendantFocusability="blocksDescendants"
        android:background="@android:color/white">

        <LinearLayout
            android:id="@+id/layoutPrincipal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:background="@drawable/background_cadre_orange"
            android:orientation="vertical"
            android:padding="5dp"
            android:weightSum="4">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="5dp">

                <TextView
                    android:id="@+id/LabelEmplacement"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Emplacement"
                    android:textColor="@color/noir"/>

                <TextView
                    android:id="@+id/nomEmplacement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="right"
                    android:text="emplacement"
                    android:textSize="15dp"
                    android:gravity="right"
                    android:textColor="@color/noir"
                    android:textStyle="bold" />

            </LinearLayout>

            <ImageView
                android:id="@+id/separateur"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/orange2"/>

            <LinearLayout
                android:id="@+id/layoutGauche"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="5dp"
                android:weightSum="6">


                <LinearLayout
                    android:id="@+id/layoutStock"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_gravity="center"
                    android:layout_marginTop="2dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/labelStock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Stock"
                        android:textColor="@color/noir"
                        android:gravity="center"/>

                    <TextView
                        android:id="@+id/qteStock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="15"
                        android:textSize="15dp"
                        android:gravity="center|center_vertical"
                        android:textColor="@color/noir"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="5"
                    android:layout_margin="2dp"
                    android:orientation="vertical"
                    android:paddingLeft="10dp">

                    <LinearLayout
                        android:id="@+id/zoneLot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/labelLot"
                            android:layout_width="45dp"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="10dp"
                            android:text="Lot"
                            android:textColor="@color/noir"/>

                        <TextView
                            android:id="@+id/lot"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="10dp"
                            android:paddingRight="10dp"
                            android:textColor="@color/noir"
                            android:textStyle="bold"
                            android:text=""/>

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/zoneDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/labelDate"
                            android:layout_width="45dp"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="10dp"
                            android:text="Date"
                            android:textColor="@color/noir"/>

                        <TextView
                            android:id="@+id/datePeremption"
                            android:layout_marginRight="5dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00/00/0000"/>


                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_stock_physique"
                    android:layout_width="48dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/background_cadre_orange"
                    android:orientation="vertical"
                    android:clickable="false"
                    android:focusable="false"
                    android:layout_marginRight="15dp"
                    android:layout_marginTop="5dp">

                    <TextView
                        android:id="@+id/qteStockPhysique"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text=""
                        android:textColor="@color/noir"
                        android:textSize="20dp"
                        android:textStyle="bold"/>


                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>
</FrameLayout>
