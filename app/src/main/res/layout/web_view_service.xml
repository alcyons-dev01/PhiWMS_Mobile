<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:weightSum="3"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/layoutDescritpion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/titreSectionDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bleu_clair_alcyons"
                android:textColor="@color/blanc"
                android:text="DESCRIPTION UTILISATION"
                android:textSize="16dp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="5dp"/>

            <TextView
                android:id="@+id/descriptionService"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/noir"
                android:padding="10dp"
                android:layout_below="@+id/titreSectionDescription"/>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <WebView
                android:id="@+id/webview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="10dp"/>

            <LinearLayout
                android:id="@+id/textEnCoursDeCreation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="center_horizontal"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/ic_movie_noir"
                    android:layout_gravity="center"
                    android:backgroundTint="@color/noir"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Vidéo en cours de création."
                    android:gravity="center"
                    android:textColor="@color/noir"/>

            </LinearLayout>


        </LinearLayout>

    </LinearLayout>

</RelativeLayout>