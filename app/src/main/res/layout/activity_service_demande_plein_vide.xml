<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context="fr.alcyons.phimr4.ReceptionPUI.ServiceReceptionPuiActivity">

    <RelativeLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent">


        <LinearLayout
            android:id="@+id/barreDeTitre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:background="@color/bleu_fonce_alcyons"
            android:orientation="horizontal"
            android:weightSum="4">

            <TextView
                android:id="@+id/titre"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_centerHorizontal="true"
                android:text="Liste Plein Vide"
                android:layout_gravity="center_vertical"
                android:layout_weight="4"
                android:textColor="#FFFFFF"
                android:textSize="24dp"
                android:paddingStart="10dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/nbElementInAdapter"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_centerHorizontal="true"
                android:text=""
                android:paddingEnd="20dp"
                android:textColor="@color/bleu_clair_alcyons"
                android:textSize="24dp"
                android:textStyle="bold" />
        </LinearLayout>


        <LinearLayout
            android:id="@+id/lancerScan"
            android:layout_below="@id/barreDeTitre"
            android:layout_width="match_parent"
            android:layout_height="50sp"
            android:background="@drawable/background_plain_rouge"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginVertical="5dp"
            android:layout_marginHorizontal="5dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:weightSum="4">

            <TextView
                android:id="@+id/textLancerScan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="SCANNER"
                android:layout_gravity="center"
                android:gravity="center_vertical"
                android:layout_weight="4"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:paddingStart="10dp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/iconLancerScan"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="10dp"
                android:layout_gravity="center_vertical"
                android:background="@drawable/ic_datamatrix"/>
        </LinearLayout>

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefreshLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/lancerScan"
            android:orientation="vertical"
            android:paddingLeft="10dp"
            android:paddingRight="10dp">

            <ListView
                android:id="@+id/listeView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:descendantFocusability="afterDescendants">

            </ListView>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </RelativeLayout>
</RelativeLayout>
