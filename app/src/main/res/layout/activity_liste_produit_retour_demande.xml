<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:id="@+id/barreDeTitre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:background="@color/bleu_fonce_alcyons"
        android:orientation="vertical">



        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/nbElementInAdapter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_toLeftOf="@+id/titre"
                android:gravity="center"
                android:text="nbElements"
                android:textColor="@color/bleu_clair_alcyons"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/titre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text="Produits"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/nomDepot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginLeft="15dp"
            android:text="NomDepot"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/SelectionParScan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/barreDeTitre"
        android:layout_margin="5dp"
        android:orientation="horizontal"
        android:clickable="true"
        android:weightSum="1.5">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:text="Sélection par scan"
            android:gravity="center"
            android:textSize="17sp"
            android:textColor="@color/bleu_clair_alcyons"
            android:textStyle="bold"/>

        <ImageView
            android:id="@+id/boutonRechercheDataMatrixProduit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="0.5"
            android:layout_marginRight="20dp"
            android:clickable="true"
            android:src="@drawable/ic_datamatrix"
            android:tint="@color/bleu_clair_alcyons" />


    </LinearLayout>

    <ImageView
        android:id="@+id/separateur2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_below="@+id/SelectionParScan"
        android:background="@android:color/darker_gray" />


    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/separateur2"
        android:layout_above="@+id/separateur"
        android:orientation="vertical"
        android:paddingLeft="10dp"
        android:paddingRight="10dp">

        <ListView
            android:id="@+id/listeView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:descendantFocusability="afterDescendants">

        </ListView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    <ImageView
        android:id="@+id/separateur"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_above="@+id/boutonSave"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:background="@android:color/darker_gray" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/separateur"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:weightSum="2">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:text="Nombre produits sélectionnés"
            android:layout_marginLeft="6dp"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/nb_prod_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="nbProd"
            android:gravity="center"
            android:layout_gravity="center"
            android:textColor="@color/bleu_clair_alcyons"
            android:textSize="23sp"
            android:textStyle="bold" />

    </LinearLayout>

    <com.github.clans.fab.FloatingActionButton
        android:id="@+id/boutonSave"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_margin="@dimen/fab_margin"
        android:src="@drawable/ic_arrowright"
        app:fab_colorNormal="@android:color/white"
        app:fab_colorPressed="@android:color/white"
        app:fab_colorRipple="@android:color/white"
        app:fab_size="normal" />

</RelativeLayout>
