<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:elevation="8dp">

    <!-- Header : Désignation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bleu_fonce_alcyons"
        android:padding="14dp">

        <TextView
            android:id="@+id/designationReference_TV"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/blanc"
            android:textStyle="bold"
            android:gravity="center"
            android:maxLines="3"
            android:ellipsize="end"/>

    </LinearLayout>

    <!-- Bandeau nouvelle référence -->
    <LinearLayout
        android:id="@+id/bandeauNouveauLot_LL"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#C62828"
        android:padding="8dp"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nouveau lot"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"/>

    </LinearLayout>

    <!-- Corps principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F0F4FF"
        android:padding="12dp">

        <!-- Emplacement -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#E8EAF6">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Emplacement"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="12sp"
                    android:alpha="0.7"
                    android:gravity="center_vertical"/>

                <TextView
                    android:id="@+id/emplacementLot_TV"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:gravity="end|center_vertical"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Lot + Péremption sur la même ligne -->
        <LinearLayout
            android:id="@+id/layoutLotPeremption_LL"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="10dp"
            android:visibility="gone">

            <!-- Lot -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E8EAF6">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lot"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="10sp"
                        android:alpha="0.6"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/numeroLot_ET"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:inputType="text"
                            android:textColor="@color/bleu_fonce_alcyons"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:background="@android:color/transparent"
                            android:padding="0dp"
                            android:gravity="center_vertical"/>

                        <ImageView
                            android:id="@+id/effacerLot_IV"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_clear"
                            app:tint="@color/bleu_fonce_alcyons"
                            android:alpha="0.6"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!-- Péremption -->
            <androidx.cardview.widget.CardView
                android:id="@+id/layoutDatePeremption_CV"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E8EAF6">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Péremption"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="10sp"
                        android:alpha="0.6"/>

                    <include
                        layout="@layout/layout_selecteur_date"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Liste lot -->
        <LinearLayout
            android:id="@+id/layoutListeLot_LL"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="10dp"
            android:visibility="visible">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardViewListLot"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E8EAF6">

                <LinearLayout
                    android:id="@+id/listeLotDisponible_LL"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lots disponibles"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="10sp"
                        android:alpha="0.6"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <AutoCompleteTextView
                            android:id="@+id/lot_Autocomplete"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:textColor="@color/bleu_fonce_alcyons"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:paddingVertical="10dp"
                            android:paddingHorizontal="12dp"
                            android:minHeight="48dp"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:cursorVisible="false"
                            android:dropDownHeight="wrap_content"/>

                        <ImageView
                            android:id="@+id/chevronFiltre"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/chevron_down_24dp"
                            android:layout_marginStart="8dp"
                            app:tint="@color/bleu_fonce_alcyons"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Quantité -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#E8EAF6">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quantité"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="10sp"
                    android:alpha="0.6"
                    android:layout_marginBottom="6dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/layoutMoins_LL"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/minus_circle"/>

                    <EditText
                        android:id="@+id/quantiteComptee_ET"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:inputType="number"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:background="@android:color/transparent"/>

                    <ImageView
                        android:id="@+id/layoutPlus_LL"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/ic_plus"/>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Bandeau Fermer / Valider -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bleu_fonce_alcyons">

        <LinearLayout
            android:id="@+id/layoutFermer_LL"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="14dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_croix_rouge"/>

        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#33FFFFFF"/>

        <LinearLayout
            android:id="@+id/layoutValider_LL"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="14dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/bleu_clair_alcyons"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>