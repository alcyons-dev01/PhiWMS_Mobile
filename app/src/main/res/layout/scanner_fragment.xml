<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/noir"
    >

    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/barcodeView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:zxing_viewfinder_laser_visibility="true"
        app:zxing_framing_rect_width="150dp"
        app:zxing_framing_rect_height="150dp"/>

    <LinearLayout
        android:id="@+id/layoutFondValidation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/vert"
        android:orientation="vertical"
        android:alpha="0.7"
        android:visibility="gone"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top">

        <ImageButton
            android:id="@+id/btnFlash"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:background="@drawable/bouton_flash"
            android:src="@drawable/ic_flash"
            android:contentDescription="Flash"
            android:scaleType="centerInside"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btnAlcyons"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:background="@drawable/bouton_alcyons"
            android:src="@drawable/ic_setting"
            android:contentDescription="Alcyons"
            android:scaleType="centerInside"/>

        <ImageButton
            android:id="@+id/btnActiveSon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:background="@drawable/bouton_son_actif"
            android:src="@drawable/ic_sound_active"
            android:contentDescription="Alcyons"
            android:scaleType="centerInside"/>

        <ImageButton
            android:id="@+id/btnInactiveSon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="16dp"
            android:background="@drawable/bouton_son_inactif"
            android:src="@drawable/ic_sound_disable"
            android:contentDescription="Alcyons"
            android:scaleType="centerInside"
            android:visibility="gone"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="16dp"
            android:background="@drawable/bouton_close"
            android:src="@drawable/ic_close"
            android:contentDescription="Quitter le scan"/>

    </LinearLayout>

</FrameLayout>