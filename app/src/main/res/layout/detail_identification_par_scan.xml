<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <RelativeLayout
        android:id="@+id/frameLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- ═══════════════════════════════════════════════════
                 TIER 1 — Fragment scanner (1/3 fixe)
            ═══════════════════════════════════════════════════════ -->
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/scannerContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- ═══════════════════════════════════════════════════
                 TIER 2 — Fiche produit (wrap_content)
            ═══════════════════════════════════════════════════════ -->
            <androidx.cardview.widget.CardView
                android:id="@+id/barreDeTitre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#F0F4FF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <!-- Désignation -->
                    <TextView
                        android:id="@+id/nomProduit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textStyle="bold"
                        android:maxLines="3"
                        android:ellipsize="end"
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="15sp"
                        android:layout_marginBottom="6dp"
                        android:gravity="center_vertical" />

                    <!-- Référence + Fournisseur -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/referenceFournisseur"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            android:textColor="@color/bleu_fonce_alcyons"
                            android:textSize="11sp"
                            android:alpha="0.7"
                            android:gravity="center_vertical" />

                        <TextView
                            android:id="@+id/nomFournisseur"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="—"
                            android:textColor="@color/bleu_fonce_alcyons"
                            android:textSize="11sp"
                            android:alpha="0.7"
                            android:gravity="end|center_vertical" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="4dp"
                        android:background="@color/bleu_clair_alcyons_transparent" />

                    <LinearLayout
                        android:id="@+id/zoneDetailsProduit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">
                        <!-- Catégorie -->
                        <LinearLayout
                            android:id="@+id/zoneCategorie"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:minHeight="28dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Catégorie"
                                android:textColor="@color/bleu_fonce_alcyons"
                                android:textSize="10sp"
                                android:alpha="0.6"
                                android:gravity="center_vertical" />

                            <TextView
                                android:id="@+id/categorie"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text=""
                                android:textColor="@color/bleu_fonce_alcyons"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:gravity="end|center_vertical" />

                        </LinearLayout>

                        <View
                            android:id="@+id/separateurCategorie"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="4dp"
                            android:background="@color/bleu_clair_alcyons_transparent" />

                        <LinearLayout
                            android:id="@+id/zoneConditionnement"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:visibility="visible"
                            android:gravity="center_vertical"
                            android:minHeight="28dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:layout_gravity="center_vertical">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_colis"
                                    android:layout_gravity="center_vertical"/>

                                <TextView
                                    android:id="@+id/condAchat"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text=""
                                    android:textColor="@color/bleu_fonce_alcyons"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:maxLines="1"
                                    android:paddingLeft="4dp"
                                    android:ellipsize="end"/>

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal"
                                android:gravity="end|right"
                                android:layout_gravity="right|center_vertical">

                                <TextView
                                    android:id="@+id/condDistrib"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text=""
                                    android:textColor="@color/bleu_fonce_alcyons"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:maxLines="1"
                                    android:ellipsize="end"
                                    android:paddingRight="4dp"
                                    android:gravity="end|center_vertical" />

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/icon_produit"
                                    android:layout_gravity="center_vertical"/>

                            </LinearLayout>

                        </LinearLayout>

                        <View
                            android:id="@+id/separateurConditionnement"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="4dp"
                            android:background="@color/bleu_clair_alcyons_transparent" />

                        <!-- Classe ATC -->
                        <LinearLayout
                            android:id="@+id/zoneClassATC"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:visibility="visible"
                            android:gravity="center_vertical"
                            android:minHeight="28dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Classe ATC"
                                android:textColor="@color/bleu_fonce_alcyons"
                                android:textSize="10sp"
                                android:alpha="0.6"
                                android:gravity="center_vertical" />

                            <TextView
                                android:id="@+id/classATC"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text=""
                                android:textColor="@color/bleu_fonce_alcyons"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:gravity="end|center_vertical" />

                        </LinearLayout>

                        <View
                            android:id="@+id/separateurATC"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginVertical="4dp"
                            android:background="@color/bleu_clair_alcyons_transparent" />

                        <!-- DCI -->
                        <LinearLayout
                            android:id="@+id/zoneDCI"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:visibility="visible"
                            android:gravity="center_vertical"
                            android:minHeight="28dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="DCI"
                                android:textColor="@color/bleu_fonce_alcyons"
                                android:textSize="10sp"
                                android:alpha="0.6"
                                android:gravity="center_vertical" />

                            <TextView
                                android:id="@+id/dci"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text=""
                                android:textColor="@color/bleu_fonce_alcyons"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:maxLines="1"
                                android:ellipsize="end"
                                android:gravity="end|center_vertical" />

                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnExpandProduit"
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/iconeExpand"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="@color/bleu_fonce_alcyons"
                            android:scaleType="centerInside" />

                    </LinearLayout>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ═══════════════════════════════════════════════════
                 ZONE ACTION — Code scanné + toggle carton/unitaire + validation
                 Layout horizontal : [colonne gauche] | [bouton valider]
            ═══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/zoneAction_LL"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#E8EDF8"
                android:paddingHorizontal="8dp"
                android:paddingVertical="8dp"
                android:visibility="gone">

                <!-- Colonne gauche : code scanné + toggle -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Ligne code scanné + bouton annuler -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <!-- Code scanné -->
                        <TextView
                            android:id="@+id/codeScanné_TV"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            android:textColor="@color/bleu_fonce_alcyons"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:gravity="center_vertical" />

                        <!-- Bouton annuler le code scanné -->
                        <ImageButton
                            android:id="@+id/btnAnnulerCode"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginStart="8dp"
                            android:background="@drawable/bouton_close"
                            android:src="@drawable/ic_close"
                            android:scaleType="centerInside"
                            android:contentDescription="Annuler le code scanné" />

                    </LinearLayout>

                    <!-- Toggle carton / unitaire -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/toggle_background"
                        android:padding="3dp">

                        <!-- État : Carton -->
                        <LinearLayout
                            android:id="@+id/btnCarton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="@drawable/toggle_item_selected"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="7dp"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/iconeCarton"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_colis"
                                android:layout_marginEnd="6dp"
                                android:scaleType="centerInside" />

                            <TextView
                                android:id="@+id/labelCarton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Carton"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/bleu_fonce_alcyons" />

                        </LinearLayout>

                        <!-- État : Unitaire -->
                        <LinearLayout
                            android:id="@+id/btnUnitaire"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="@android:color/transparent"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="7dp"
                            android:gravity="center_vertical">

                            <ImageView
                                android:id="@+id/iconeUnitaire"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/icon_produit"
                                android:layout_marginEnd="6dp"
                                android:scaleType="centerInside" />

                            <TextView
                                android:id="@+id/labelUnitaire"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Unitaire"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/bleu_fonce_alcyons"
                                android:alpha="0.4" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Bouton validation — toute la hauteur de la zone action -->
                <LinearLayout
                    android:id="@+id/btnValiderCode"
                    android:layout_width="64dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/cadre_vert"
                    android:layout_marginStart="10dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_check"
                        app:tint="@color/noir"
                        android:scaleType="centerInside"
                        android:layout_marginBottom="4dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ═══════════════════════════════════════════════════
                 TIER 3 — Codes d'identification (reste de la page)
            ═══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Codes d'identification"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:alpha="0.7"
                    android:paddingHorizontal="12dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bleu_clair_alcyons_transparent"
                    android:layout_marginBottom="4dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/listeCodesIdentification_RV"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:clipToPadding="false" />

                <!-- Bouton retour à la liste — fixe en bas, hors du scroll de la RecyclerView -->
                <LinearLayout
                    android:id="@+id/btnRevenirALaListe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@color/bleu_fonce_alcyons"
                    android:paddingVertical="14dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Revenir à la liste"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>