<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_below="@+id/linearLayout"
        android:layout_above="@+id/fermerAlerteLinearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/zoneProduit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="5dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="@color/grey_color"
                    android:orientation="horizontal"
                    android:padding="0dp">

                    <ImageView
                        android:id="@+id/photo"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_alignParentBottom="true"
                        android:layout_centerInParent="true"
                        android:adjustViewBounds="true"
                        android:background="@color/grey_color"
                        android:contentDescription="@string/photoProduit" />

                    <TextView
                        android:id="@+id/nomProduit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="0dp"
                        android:background="@color/grey_color_fonce_50Pourcent"
                        android:gravity="top|center"
                        android:padding="0dp"
                        android:text="Aranesp 10 microgrammes"
                        android:textAlignment="center"
                        android:textColor="@color/blanc"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:background="@color/grey_color_fonce_50Pourcent"
                        android:weightSum="2">

                        <TextView
                            android:id="@+id/fournisseurProduit"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_margin="2dp"
                            android:textAlignment="textStart"
                            android:text="AMGEN"
                            android:textColor="@color/blanc"/>

                        <TextView
                            android:id="@+id/referenceProduit"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_margin="2dp"
                            android:textAlignment="textEnd"
                            android:text="seringue pré-remplie - 0.4 ml"
                            android:textColor="@color/blanc" />

                    </LinearLayout>

                </RelativeLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/zoneSaisieComposantPrescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="5dp"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_weight="1">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Nombre de carton fermé"
                        android:textColor="@drawable/black_color" />

                    <TextView
                        android:id="@+id/conditionnementProduit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text=""
                        android:textColor="@drawable/black_color" />

                    <EditText
                        android:id="@+id/qteCartonFerme"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:digits="0123456789"
                        android:gravity="center"
                        android:imeOptions="actionDone"
                        android:inputType="phone"
                        android:text="0"
                        android:textSize="30sp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="2dp"
                    android:layout_height="match_parent"
                    android:background="@color/bleu_clair_alcyons" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_weight="1">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Un carton ouvert ?\nSaisissez le nombre d'unité"
                        android:textColor="@drawable/black_color" />

                    <EditText
                        android:id="@+id/qteUnite"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:digits="0123456789"
                        android:gravity="center"
                        android:imeOptions="actionDone"
                        android:inputType="phone"
                        android:text="0"
                        android:textSize="30sp" />

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/zoneSaisieDotation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="5dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/dotationQteALivrerLinearLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="En quelle quantité ?"
                        android:textColor="@drawable/black_color"/>

                    <EditText
                        android:id="@+id/dotationQteALivrer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:inputType="phone"
                        android:digits="0123456789"
                        android:imeOptions="actionDone"
                        android:text="0"
                        android:textSize="30sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Souhaitez-vous recevoir ce produit  ?"
                    android:textColor="@drawable/black_color"/>

                <LinearLayout
                    android:id="@+id/recevoirProduitLinearLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    android:weightSum="2"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/recevoirProduitOui"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="OUI"
                        android:textStyle="bold"
                        android:textColor="@color/vert"
                        android:clickable="true"
                        android:onClick="onClick_recevoirProduitOui"
                        android:textSize="30sp"/>

                    <TextView
                        android:id="@+id/recevoirProduitNon"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_weight="1"
                        android:text="NON"
                        android:textStyle="bold"
                        android:textColor="@color/rouge"
                        android:clickable="true"
                        android:textSize="30sp"
                        android:onClick="onClick_recevoirProduitNon"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>


    </ScrollView>

    <LinearLayout
        android:id="@+id/fermerAlerteLinearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_gravity="center"
            android:background="@color/grey_color_fonce" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_check_circle"

            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:backgroundTint="@color/bleu_clair_alcyons"
            android:layout_gravity="center_horizontal" />

    </LinearLayout>
</RelativeLayout>