<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:backgroundTint="@android:color/white">

    <RelativeLayout
        android:id="@+id/relative_principal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="5dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/background_preparation_bleu">

        <LinearLayout
            android:id="@+id/zone_info_reception"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:background="@color/bleu_clair_alcyons"
            android:padding="5dp">

            <TextView
                android:id="@+id/numero"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.5"
                android:textColor="@color/noir"
                android:textStyle="bold"
                android:textSize="15dp"
                android:text="#"/>

            <TextView
                android:id="@+id/motif"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2.5"
                android:textColor="@color/noir"
                android:textSize="15dp"
                android:gravity="right"
                android:text="En cours"/>


        </LinearLayout>

        <LinearLayout
            android:id="@+id/zone_detail_reception"
            android:layout_below="@+id/zone_info_reception"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="5">


            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="4"
                android:orientation="vertical"
                android:padding="5dp">

                <TextView
                    android:id="@+id/depotOrigine"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"
                    android:text=""
                    android:textSize="18dp"
                    android:textColor="@color/noir"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/intitule"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"
                    android:text=""
                    android:textSize="16dp"
                    android:textColor="@color/noir"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ZoneNbColisEnAttente"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="@color/orange2"
                android:padding="5dp"
                android:gravity="center_vertical"
                android:layout_marginLeft="2dp">

                <TextView
                    android:id="@+id/sommeProduit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18dp"
                    android:textColor="@color/blanc"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ref."
                    android:textSize="16dp"
                    android:gravity="center"
                    android:textColor="@color/blanc"/>

            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

</RelativeLayout>