<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentLeft="true"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginBottom="10dp"
        android:background="@drawable/background_element_list_droit"
        android:padding="5dp">

        <LinearLayout
            android:id="@+id/zoneDesignation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="1">

            <TextView
                android:id="@+id/designationProduit"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:text=""
                android:textColor="@android:color/black"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/zoneReferences"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/zoneDesignation"
            android:orientation="horizontal"
            android:weightSum="10">

            <TextView
                android:id="@+id/referenceProduit"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_weight="5"
                android:text="" />

            <TextView
                android:id="@+id/nomFournisseur"
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_weight="5"
                android:text=""
                android:textColor="@android:color/black" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/zoneQuarantaine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:layout_below="@id/zoneReferences"
            android:orientation="horizontal"
            android:weightSum="5">

            <FrameLayout
                android:id="@+id/zoneLot"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="2.5"
                android:weightSum="2.5"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/lotRetourne"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:text=""
                    android:paddingLeft="40dp"
                    android:background="@drawable/background_element_trait_bottom"
                    android:textColor="@android:color/black"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/lot"
                    android:layout_gravity="center_vertical"
                    android:paddingLeft="10dp"/>

            </FrameLayout>


            <FrameLayout
                android:id="@+id/zoneDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="2.5"
                android:layout_marginLeft="10dp"
                android:background="@drawable/background_element_trait_bottom"
                android:weightSum="2.5">

                <TextView
                    android:id="@+id/datePeremption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:layout_gravity="center_vertical"
                    android:paddingLeft="30dp"
                    android:textColor="@android:color/holo_red_light"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="@string/datePeremption" />
            </FrameLayout>

            <LinearLayout
                android:id="@+id/zoneDataMatrix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginLeft="10dp"
                android:orientation="horizontal"
                android:weightSum="1">

                <ImageView
                    android:id="@+id/imageView2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:contentDescription="@string/datamatrix"
                    android:background="@drawable/ic_datamatrix"
                    android:backgroundTint="@color/bleu_clair_alcyons" />
            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/zoneNumSerie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/zoneQuarantaine"
            android:orientation="horizontal"
            android:weightSum="6">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_weight="4.4"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/numeroSerieModifiable"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingLeft="50dp"
                    android:text=""
                    android:textSize="15dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="10dp"
                    android:layout_gravity="center_vertical"
                    android:text="Série "/>

            </FrameLayout>

            <TextView
                android:id="@+id/resultatSerialisation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.6"
                android:gravity="center"
                android:text=""/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/zoneNumSerie"
            android:orientation="horizontal"
            android:weightSum="4">

            <LinearLayout
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/Quarantaine" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:contentDescription="@string/separateur"
                    android:background="@color/orange2" />

                <TextView
                    android:id="@+id/QteRetourner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text=""
                    android:textColor="@color/orange2"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/Destruction" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:contentDescription="@string/separateur"
                    android:background="@color/rouge2" />

                <TextView
                    android:id="@+id/QteDestruction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:gravity="center"
                    android:text=""
                    android:textSize="18dp"
                    android:textColor="@color/noir"
                    android:background="@color/rougeTransparent"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/RetourPUI" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:contentDescription="@string/separateur"
                    android:background="@color/vert2" />

                <TextView
                    android:id="@+id/QteRetourPUI"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:gravity="center"
                    android:nextFocusDown="@+id/QteRetourFournisseur"
                    android:text=""
                    android:textSize="18dp"
                    android:textColor="@color/noir"
                    android:background="@color/vertTransparent"
                    android:textStyle="bold"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0px"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:padding="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/RetourFrs" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:contentDescription="@string/separateur"
                    android:background="@color/bleu2" />

                <TextView
                    android:id="@+id/QteRetourFournisseur"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:gravity="center"
                    android:text=""
                    android:textSize="18dp"
                    android:textColor="@color/noir"
                    android:background="@color/bleuTransparent"
                    android:textStyle="bold"/>

            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>

</RelativeLayout>