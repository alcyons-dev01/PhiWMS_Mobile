<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="6dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#F0F4FF">

        <LinearLayout
            android:id="@+id/linearLigneProduit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- ═══════════════════════════════
                 COLONNE GAUCHE : infos produit
            ═══════════════════════════════ -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:orientation="vertical">

                <!-- Header : désignation -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/bleu_fonce_alcyons"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp">

                    <TextView
                        android:id="@+id/designation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end" />

                </LinearLayout>

                <!-- Séparateur accent -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="@color/bleu_clair_alcyons" />

                <!-- Référence + Conditionnement -->
                <LinearLayout
                    android:id="@+id/entete"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="10dp"
                    android:weightSum="3">

                    <TextView
                        android:id="@+id/reference"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text=""
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="11sp"
                        android:alpha="0.7" />

                    <TextView
                        android:id="@+id/qteConditionnement"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text=""
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="11sp"
                        android:alpha="0.7" />

                </LinearLayout>

            </LinearLayout>

            <!-- ═══════════════════════════════
                 SÉPARATEUR VERTICAL
            ═══════════════════════════════ -->
            <View
                android:id="@+id/separateur"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/bleu_clair_alcyons" />

            <!-- ═══════════════════════════════
                 COLONNE DROITE : quantités
            ═══════════════════════════════ -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#F0F4FF"
                android:paddingVertical="10dp">

                <!-- Quantité à préparer (lecture) -->
                <TextView
                    android:id="@+id/qte_a_preparer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:text=""
                    android:textStyle="bold"
                    android:textColor="@color/bleu_fonce_alcyons" />

                <!-- Quantité demandée (édition) -->
                <EditText
                    android:id="@+id/qte_demander"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textSize="20sp"
                    android:text=""
                    android:textStyle="bold"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:inputType="number"
                    android:selectAllOnFocus="true"
                    android:imeOptions="actionDone"
                    android:background="@null"
                    android:layout_marginHorizontal="8dp"
                    android:visibility="gone" />

                <!-- Séparateur fin -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bleu_clair_alcyons_transparent"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginVertical="4dp" />

                <!-- Label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Demandé"
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="11sp"
                    android:alpha="0.7" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>