<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:paddingBottom="16dp">

    <!-- ═══════════════════════════════
         CONTENU PRINCIPAL
    ═══════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- BARRE DE TITRE -->
        <LinearLayout
            android:id="@+id/barreDeTitre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bleu_fonce_alcyons"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/uidPHPreparation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/livraisonPrevueDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#BBDEFB"
                android:textSize="13sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Séparateur accent -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@color/bleu_clair_alcyons" />

        <!-- SCROLL : contact + infos -->
        <LinearLayout
            android:id="@+id/zoneHautLinearLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ScrollView
                android:id="@+id/scrollView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- CARTE CONTACT -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="8dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#F0F4FF">

                        <LinearLayout
                            android:id="@+id/zoneContact"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <!-- Identité + chevrons -->
                            <LinearLayout
                                android:id="@+id/layoutIdentite"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/identiteClient"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text=""
                                    android:textColor="@color/bleu_fonce_alcyons"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <ImageView
                                    android:id="@+id/deployerAdresse"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:background="@drawable/chevron_down_24dp"
                                    android:backgroundTint="@color/bleu_clair_alcyons"
                                    android:contentDescription="@null" />

                                <ImageView
                                    android:id="@+id/replierAdresse"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:background="@drawable/chevron_up_24dp"
                                    android:backgroundTint="@color/bleu_clair_alcyons"
                                    android:visibility="gone"
                                    android:contentDescription="@null" />

                            </LinearLayout>

                            <!-- Adresse + Téléphone -->
                            <LinearLayout
                                android:id="@+id/layoutAdresse"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:visibility="gone">

                                <View
                                    android:layout_width="match_parent"
                                    android:layout_height="1dp"
                                    android:background="@color/bleu_clair_alcyons_transparent"
                                    android:layout_marginVertical="10dp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginBottom="10dp">

                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:background="@drawable/ic_location_black"
                                        android:backgroundTint="@color/bleu_clair_alcyons"
                                        android:layout_marginEnd="8dp"
                                        android:contentDescription="@null" />

                                    <TextView
                                        android:id="@+id/adresse"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text=""
                                        android:linksClickable="true"
                                        android:autoLink="map"
                                        android:onClick="adresseDepot"
                                        android:textColor="@color/bleu_fonce_alcyons"
                                        android:textSize="14sp"
                                        android:textStyle="bold" />

                                </LinearLayout>

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:background="@drawable/ic_phone"
                                        android:backgroundTint="@color/bleu_clair_alcyons"
                                        android:layout_marginEnd="8dp"
                                        android:contentDescription="@null" />

                                    <TextView
                                        android:id="@+id/telephone"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text=""
                                        android:autoLink="phone"
                                        android:linksClickable="true"
                                        android:onClick="telephoneDepot"
                                        android:textColor="@color/bleu_fonce_alcyons"
                                        android:textSize="14sp"
                                        android:textStyle="bold" />

                                </LinearLayout>

                            </LinearLayout>

                            <!-- Bandeau URGENT -->
                            <TextView
                                android:id="@+id/isUrgent"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="URGENT"
                                android:background="#C62828"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:paddingVertical="6dp"
                                android:layout_marginTop="10dp"
                                android:visibility="gone" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <!-- CARTE COMMENTAIRE -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="8dp"
                        android:layout_marginVertical="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#F0F4FF">

                        <LinearLayout
                            android:id="@+id/zoneCommentaire"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <TextView
                                android:id="@+id/commentaire"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/bleu_fonce_alcyons"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Commentaire"
                                android:textSize="11sp"
                                android:textColor="@color/bleu_fonce_alcyons"
                                android:alpha="0.6" />

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <!-- CARTE INDICATEURS -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="8dp"
                        android:layout_marginVertical="4dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#F0F4FF">

                        <LinearLayout
                            android:id="@+id/zoneInformations"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="5"
                            android:paddingVertical="12dp">

                            <!-- Colis -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:background="@drawable/ic_colis"
                                    android:backgroundTint="@color/bleu_clair_alcyons"
                                    android:layout_marginBottom="4dp"
                                    android:contentDescription="@null" />

                                <TextView
                                    android:id="@+id/nbColis"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:textStyle="bold"
                                    android:textSize="15sp"
                                    android:textColor="@color/bleu_fonce_alcyons"
                                    android:gravity="center" />

                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="@color/bleu_clair_alcyons_transparent" />

                            <!-- M3 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="M³"
                                    android:gravity="center"
                                    android:textColor="@color/bleu_fonce_alcyons"
                                    android:textSize="12sp"
                                    android:alpha="0.6"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/volume"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:textSize="15sp"
                                    android:textColor="@color/bleu_fonce_alcyons"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="@color/bleu_clair_alcyons_transparent" />

                            <!-- Réf. -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Réf."
                                    android:gravity="center"
                                    android:textColor="@color/bleu_fonce_alcyons"
                                    android:textSize="12sp"
                                    android:alpha="0.6"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/nbRef"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:textStyle="bold"
                                    android:textSize="15sp"
                                    android:textColor="@color/bleu_fonce_alcyons" />

                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="@color/bleu_clair_alcyons_transparent" />

                            <!-- Kg -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Kg"
                                    android:gravity="center"
                                    android:textColor="@color/bleu_fonce_alcyons"
                                    android:textSize="12sp"
                                    android:alpha="0.6"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/poidsTotal"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:textStyle="bold"
                                    android:textSize="15sp"
                                    android:textColor="@color/bleu_fonce_alcyons" />

                            </LinearLayout>

                            <View
                                android:layout_width="1dp"
                                android:layout_height="match_parent"
                                android:background="@color/bleu_clair_alcyons_transparent" />

                            <!-- € -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="€"
                                    android:gravity="center"
                                    android:textColor="@color/bleu_fonce_alcyons"
                                    android:textSize="12sp"
                                    android:alpha="0.6"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/montantTTC"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:gravity="center"
                                    android:textSize="15sp"
                                    android:textColor="@color/bleu_fonce_alcyons"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </ScrollView>

        </LinearLayout>

        <!-- LISTE -->
        <ListView
            android:id="@+id/listeView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:descendantFocusability="afterDescendants"
            android:divider="@android:color/transparent"
            android:dividerHeight="0dp"
            android:paddingBottom="80dp"
            android:clipToPadding="false" />

    </LinearLayout>

    <!-- ═══════════════════════════════
         FAB — ancré en absolu
         en bas à droite de l'écran
    ═══════════════════════════════ -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/floatingMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="16dp"
        app:srcCompat="@drawable/ic_setting"
        app:backgroundTint="@color/bleu_clair_alcyons"
        app:tint="#FFFFFF"
        app:elevation="6dp"
        app:fabSize="normal"/>

</RelativeLayout>