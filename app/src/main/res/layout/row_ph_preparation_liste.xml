<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#F0F4FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header : Date + Urgent -->
        <LinearLayout
            android:id="@+id/zoneDateLivraisonPrevue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/bleu_fonce_alcyons"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:weightSum="2">

            <TextView
                android:id="@+id/livraisonPrevueDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center_vertical"/>

            <TextView
                android:id="@+id/preparationUrgente"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:text="URGENT"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FF5252"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- Corps -->
        <LinearLayout
            android:id="@+id/cartePreparation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F0F4FF"
            android:padding="10dp"
            android:gravity="center_vertical">

            <!-- Zone gauche : Dépôt + UID + Origine -->
            <LinearLayout
                android:id="@+id/zoneGauche"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="4"
                android:layout_gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/depotNom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/uidPHPreparation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="13sp"
                    android:alpha="0.8"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/origine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/bleu_fonce_alcyons"
                    android:textSize="12sp"
                    android:alpha="0.6"
                    android:maxLines="2"
                    android:ellipsize="end"/>

            </LinearLayout>

            <!-- Séparateur -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/bleu_clair_alcyons_transparent"
                android:layout_marginHorizontal="8dp"/>

            <!-- Zone droite : Nb à préparer — centré verticalement -->
            <androidx.cardview.widget.CardView
                android:id="@+id/zoneDroite"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bleu_fonce_alcyons">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="8dp">

                    <TextView
                        android:id="@+id/nbAPreparer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="À préparer"
                        android:textColor="#AAAAFF"
                        android:textSize="10sp"
                        android:gravity="center"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>