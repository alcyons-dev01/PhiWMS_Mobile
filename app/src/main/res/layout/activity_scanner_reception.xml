<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/bleu_fonce_alcyons"
    android:backgroundTint="@color/bleu_fonce_alcyons">

    <!-- ENTETE PREPARATION -->
    <LinearLayout
        android:id="@+id/entetePreparation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3">

        <TextView
            android:id="@+id/numPreparation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:paddingStart="10dp"
            android:layout_gravity="center_vertical"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <ImageView
                android:id="@+id/imageLogoFMVO"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@mipmap/fmvo_25"
                android:visibility="gone"/>

        </LinearLayout>

        <TextView
            android:id="@+id/depot"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:gravity="end"
            android:layout_gravity="center_vertical"
            android:paddingEnd="10dp"
            android:layout_weight="1"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ENTETE BOUTON BARCODE -->
    <RelativeLayout
        android:id="@+id/LinearLayoutBoutonBarcode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="visible"
        android:paddingHorizontal="10dp"
        android:layout_marginTop="10dp"
        android:layout_below="@+id/entetePreparation">

        <com.github.clans.fab.FloatingActionButton
            android:id="@+id/scannerMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_lecteur"
            app:fab_size="mini"
            app:fab_colorNormal="@android:color/holo_red_light"
            app:fab_colorPressed="@android:color/holo_red_light"
            app:fab_colorRipple="@android:color/holo_red_light"
            app:fab_label="Lecteur code-barre" />

        <com.github.clans.fab.FloatingActionButton
            android:id="@+id/boutonFermeture"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_clear"
            app:fab_size="mini"
            android:layout_alignParentEnd="true"
            app:fab_colorNormal="@color/grey_color"
            app:fab_colorPressed="@color/grey_color"
            app:fab_colorRipple="@color/grey_color"
            app:fab_label="Quitter"/>

    </RelativeLayout>

    <!-- IMAGE SCAN PRODUIT & EMPLACEMENT -->
    <ImageView
        android:id="@+id/ImageViewEmplacement"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/phitagplace"
        android:visibility="visible"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:layout_centerInParent="true"
        android:layout_below="@+id/LinearLayoutBoutonBarcode"/>

    <!-- TEXT VIEW EMPLACEMENT -->
    <TextView
        android:id="@+id/EmplacementLotProduit"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="@drawable/background_emplacement_barcode"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginTop="15dp"
        android:padding="2dp"
        android:layout_below="@+id/ImageViewEmplacement"
        android:visibility="gone"/>

    <!-- IMAGE SCAN PRODUIT & EMPLACEMENT -->
    <ImageView
        android:id="@+id/ImageViewProduit"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/phitagprod"
        android:layout_marginTop="15dp"
        android:layout_gravity="center"
        android:layout_below="@+id/EmplacementLotProduit"
        android:layout_centerInParent="true"
        android:visibility="gone"/>

    <!-- TEXT VIEW INSTRUCTION -->
    <TextView
        android:id="@+id/instruction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/rouge"
        android:text="Scannez un emplacement"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="2dp"
        android:layout_marginTop="15dp"
        android:layout_below="@+id/ImageViewProduit"
        android:visibility="visible"/>

    <!-- EDIT TEXT SCAN -->
    <LinearLayout
        android:id="@+id/layoutTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="15dp"
        android:layout_below="@+id/instruction">

        <EditText
            android:id="@+id/EditTextScanee"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:gravity="center"
            android:layout_margin="10dp"
            android:focusable="true"
            android:textColor="@color/blanc"
            android:textSize="18dp"
            android:text=""/>

    </LinearLayout>

    <!-- LAYOUT FILM VALIDATION -->
    <LinearLayout
        android:id="@+id/layoutIconeValidation"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <TextView
            android:id="@+id/designationValidation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="18dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text=""/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_vertical"
            android:layout_marginTop="10dp"
            android:paddingStart="10dp"
            android:weightSum="3">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="left"
                android:text="Lot : "
                android:textColor="@color/blanc"
                android:textSize="16dp"/>

            <TextView
                android:id="@+id/lotValidation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="2"
                android:gravity="left"
                android:text=""
                android:textColor="@color/blanc"
                android:textSize="18dp"
                android:textStyle="bold" />


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginTop="10dp"
            android:paddingStart="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/blanc"
                android:textSize="16dp"
                android:gravity="left"
                android:layout_gravity="center_vertical"
                android:text="Date Exp. : "/>

            <TextView
                android:id="@+id/peremptionValidation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textColor="@color/blanc"
                android:textSize="18dp"
                android:gravity="left"
                android:textStyle="bold"
                android:layout_gravity="center_vertical"
                android:text=""/>


        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutSerieValidation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginTop="10dp"
            android:paddingStart="10dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/blanc"
                android:textSize="16dp"
                android:gravity="left"
                android:layout_gravity="center_vertical"
                android:text="Série : "/>

            <TextView
                android:id="@+id/serieValidation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textColor="@color/blanc"
                android:textSize="18dp"
                android:gravity="left"
                android:textStyle="bold"
                android:layout_gravity="center_vertical"
                android:text=""/>


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginTop="10dp"
            android:paddingStart="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/blanc"
                android:textSize="16dp"
                android:gravity="left"
                android:layout_gravity="center_vertical"
                android:text="Place : "/>

            <TextView
                android:id="@+id/emplacementValidation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textColor="@color/blanc"
                android:textSize="18dp"
                android:gravity="left"
                android:textStyle="bold"
                android:layout_gravity="center_vertical"
                android:text=""/>

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBarQuantite"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="20dp"
            android:max="5"
            android:progress="0"
            android:indeterminate="false"
            android:progressDrawable="@drawable/progress_drawable_encours"/>

        <TextView
            android:id="@+id/quantiteValidation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            android:layout_gravity="center_vertical"
            android:text="10/25"/>

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/validate_bleu"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:visibility="visible"
            android:layout_marginTop="20dp"/>
    </LinearLayout>

    <!-- LAYOUT FILM PRODUIT COMPLET -->
    <LinearLayout
        android:id="@+id/layoutProduitComplet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <ImageView
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/validate"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:visibility="visible"/>

        <TextView
            android:id="@+id/designationComplete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text=""/>


        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="14dp"
            android:layout_marginHorizontal="15dp"
            android:max="5"
            android:progress="5"
            android:indeterminate="false"
            android:progressTint="@color/vert"
            android:progressDrawable="@drawable/progress_drawable_encours"/>

        <TextView
            android:id="@+id/quantiteComplete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/blanc"
            android:textSize="32dp"
            android:gravity="center"
            android:textStyle="bold"
            android:layout_gravity="center_vertical"
            android:text=""/>

    </LinearLayout>

    <!-- LAYOUT FILM PRODUIT ABSENT -->
    <LinearLayout
        android:id="@+id/layoutProduitAbsent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <ImageView
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/ic_croix_rouge"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:visibility="visible"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text="Référence absente\nde la réception"/>

    </LinearLayout>

    <!-- LAYOUT FILM PRODUIT INCONNU -->
    <LinearLayout
        android:id="@+id/layoutProduitInconnu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <ImageView
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/ic_croix_rouge"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:visibility="visible"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text="Référence inconnue\nen base de données"/>

    </LinearLayout>

    <!-- LAYOUT FILM SERIE SCANNEE -->
    <LinearLayout
        android:id="@+id/layoutSerieScannee"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <ImageView
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/ic_croix_rouge"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:visibility="visible"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text="Numéro de série\ndéjà scanné"/>
    </LinearLayout>

    <!-- LAYOUT FILM SERIE NON SCANNEE -->
    <LinearLayout
        android:id="@+id/layoutSerieNonScannee"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <ImageView
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:layout_centerHorizontal="true"
            android:background="@drawable/ic_croix_rouge"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:visibility="visible"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text="Numéro de série\nabsent du scan"/>

    </LinearLayout>

    <!-- LAYOUT FILM SCANNER EMPLACEMENT -->
    <LinearLayout
        android:id="@+id/layoutScannerEmplacement"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <ImageView
            android:layout_width="128dp"
            android:layout_height="128dp"
            android:background="@drawable/phitagplace"
            android:visibility="visible"
            android:layout_gravity="center"
            android:layout_centerInParent="true"
            android:layout_below="@+id/LinearLayoutBoutonBarcode"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text="Scannez un\nemplacement"/>

    </LinearLayout>

    <!-- LAYOUT FILM SCANNER EMPLACEMENT -->
    <LinearLayout
        android:id="@+id/layoutScannerEmplacementInconnu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/noir"
        android:alpha="0.9"
        android:gravity="center"
        android:visibility="invisible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/phitagplace"
                    android:visibility="visible"
                    android:layout_gravity="center"
                    android:layout_centerInParent="true"
                    android:layout_below="@+id/LinearLayoutBoutonBarcode"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:background="@drawable/ic_croix_rouge"
                    android:visibility="visible"
                    android:layout_gravity="center"
                    android:layout_centerInParent="true"
                    android:layout_below="@+id/LinearLayoutBoutonBarcode"/>

            </LinearLayout>


        </LinearLayout>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/blanc"
            android:textSize="24dp"
            android:gravity="center"
            android:textStyle="bold"
            android:text="Emplacement scanné inconnu"/>

    </LinearLayout>
</RelativeLayout>
