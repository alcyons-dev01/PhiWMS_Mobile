<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="6dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#F0F4FF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══════════════════════════════
                 HEADER : Nom dispositif
            ═══════════════════════════════ -->
            <LinearLayout
                android:id="@+id/layoutNomDispositif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bleu_fonce_alcyons"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:gravity="center_horizontal">

                <TextView
                    android:id="@+id/nomDispositif"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />

            </LinearLayout>

            <!-- Séparateur accent -->
            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="@color/bleu_clair_alcyons" />

            <!-- ═══════════════════════════════
                 CORPS : Fournisseur + Type
            ═══════════════════════════════ -->
            <LinearLayout
                android:id="@+id/titreDispositif"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp">

                <LinearLayout
                    android:id="@+id/layoutSecondaire"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <TextView
                        android:id="@+id/nomFournisseur"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text=""
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="12sp"
                        android:alpha="0.7" />

                    <TextView
                        android:id="@+id/type"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text=""
                        android:textColor="@color/bleu_fonce_alcyons"
                        android:textSize="12sp"
                        android:alpha="0.7" />

                </LinearLayout>

                <!-- Séparateur fin -->
                <View
                    android:id="@+id/separateur1"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bleu_clair_alcyons_transparent"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp" />

                <!-- ═══════════════════════════════
                     SYMBOLES — ligne 1
                ═══════════════════════════════ -->
                <TableLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TableRow
                        android:id="@+id/tableRowHaut"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:gravity="center_horizontal">

                        <ImageView
                            android:id="@+id/symboleusageunique"
                            android:layout_marginHorizontal="12dp"
                            android:contentDescription="@string/usageUnique"
                            android:background="@drawable/ic_symboleusageunique"
                            android:visibility="invisible" />

                        <ImageView
                            android:id="@+id/symbolefragile"
                            android:layout_marginHorizontal="12dp"
                            android:contentDescription="@string/fragile"
                            android:background="@drawable/ic_symbolefragile"
                            android:visibility="invisible" />

                        <ImageView
                            android:id="@+id/symboletemperature"
                            android:layout_marginHorizontal="12dp"
                            android:contentDescription="@string/temperature"
                            android:background="@drawable/ic_symboletemperatureambiante"
                            android:visibility="invisible" />

                        <ImageView
                            android:id="@+id/symboleausec"
                            android:layout_marginHorizontal="12dp"
                            android:contentDescription="@string/auSec"
                            android:background="@drawable/ic_symboleausec"
                            android:visibility="invisible" />

                        <ImageView
                            android:id="@+id/symboleabrilumiere"
                            android:layout_marginHorizontal="12dp"
                            android:contentDescription="@string/aLAbriDeLaLumiere"
                            android:background="@drawable/ic_symboleabrilumiere"
                            android:visibility="invisible" />

                    </TableRow>

                    <!-- ═══════════════════════════════
                         SYMBOLES — ligne 2
                    ═══════════════════════════════ -->
                    <TableRow
                        android:id="@+id/tableRowBas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_horizontal">

                        <ImageView
                            android:id="@+id/symbolesterilisation"
                            android:layout_marginHorizontal="12dp"
                            android:contentDescription="@string/sterilisation"
                            android:background="@drawable/ic_symbolenonsterile"
                            android:visibility="invisible" />

                        <ImageView
                            android:id="@+id/symbolenepasresteriliser"
                            android:layout_marginHorizontal="12dp"
                            android:contentDescription="@string/nePasResteriliser"
                            android:background="@drawable/ic_symbolenepasresteriliser"
                            android:visibility="invisible" />

                        <ImageView
                            android:id="@+id/symbolerisquesubstancepresancelatex"
                            android:layout_marginHorizontal="12dp"
                            android:contentDescription="@string/risquesubstancepresancelatex"
                            android:background="@drawable/ic_symbolerisquesubstancepresencelatex"
                            android:visibility="invisible" />

                        <ImageView
                            android:id="@+id/symbolerisquesubstancepresancepht"
                            android:layout_marginHorizontal="12dp"
                            android:contentDescription="@string/risquesubstancepresancepht"
                            android:background="@drawable/ic_symbolerisquesubstancepresencepht"
                            android:visibility="invisible" />

                        <ImageView
                            android:id="@+id/symbolerisquesubstancepresance"
                            android:layout_marginHorizontal="12dp"
                            android:contentDescription="@string/risquesubstancepresance"
                            android:background="@drawable/ic_symbolerisquesubstancepresence"
                            android:visibility="invisible" />

                    </TableRow>

                </TableLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</LinearLayout>