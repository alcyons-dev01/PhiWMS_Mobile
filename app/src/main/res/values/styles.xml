<resources xmlns:android="http://schemas.android.com/tools" android:ignore="NamespaceTypo">

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/bleu_fonce_alcyons</item>
        <item name="colorPrimaryDark">@color/bleu_fonce_alcyons</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="actionModeBackground">@color/bleu_fonce_alcyons</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="colorAccent">@color/gris</item>

    </style>

    <style name="testSizeAlert">
        <item name="android:textSize">30sp</item>
    </style>

    <style name="AppTheme.NoActionBar.Fullscreen">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="MyCustomTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="textAllCaps">false</item>
        <item name="android:textAppearance">@style/CustomTabWidgetText</item>
    </style>

    <style name="CustomTabWidgetText" parent="@android:style/TextAppearance.Widget.TabWidget">
        <item name="android:textSize">3sp</item>
    </style>

    <style name="SCBSwitch" parent="Theme.AppCompat.Light">
        <!-- active thumb & track color (30% transparency) -->
        <item name="colorControlActivated">#00bd00</item>

        <!-- inactive thumb color -->
        <item name="colorSwitchThumbNormal">#bd0000
        </item>

        <!-- inactive track color (30% transparency) -->
        <item name="android:colorForeground">#000000
        </item>
    </style>

    <style name="mySpinnerItemStyle" parent="Theme.AppCompat.Light">
        <item name="android:background">@drawable/spinner_selector</item>
        <item name="android:gravity">center_vertical</item>

    </style>

    <style name="SpinnerDatePicker" parent="android:Widget.Material.DatePicker">
        <item name="android:datePickerMode">spinner</item>
        <item name="android:calendarViewShown">false</item>
    </style>

    <!-- Gestion des styles de text -->
    <style name="designation_style">
        <item name="android:textSize">@dimen/text_lg</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">@color/noir</item>
    </style>

    <style name="reference_style">
        <item name="android:textSize">@dimen/text_base</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">@color/noir</item>
    </style>

    <style name="titre_style">
        <item name="android:textSize">@dimen/text_2xl</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">@color/noir</item>
    </style>

    <style name="soustitre_style">
        <item name="android:textSize">@dimen/text_xl</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">@color/noir</item>
    </style>

    <style name="soustitregras_style">
        <item name="android:textSize">@dimen/text_xl</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/noir</item>
    </style>

    <style name="section_style">
        <item name="android:textSize">@dimen/text_lg</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">@color/noir</item>
    </style>

    <style name="sectiongras_style">
        <item name="android:textSize">@dimen/text_lg</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">@color/noir</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="text1ligne_style">
        <item name="android:textSize">@dimen/text_base</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">@color/noir</item>
    </style>

    <style name="text2ligne_style">
        <item name="android:textSize">@dimen/text_base</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">@color/noir</item>
    </style>

    <style name="text1lignegras_style">
        <item name="android:textSize">@dimen/text_base</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">@color/noir</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="text2lignegras_style">
        <item name="android:textSize">@dimen/text_base</item>
        <item name="android:maxLines">2</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">@color/noir</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="BigSwitch" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="android:switchMinWidth">80dp</item>
        <item name="android:switchPadding">10dp</item>
        <item name="android:thumbTextPadding">20dp</item>
    </style>

</resources>
