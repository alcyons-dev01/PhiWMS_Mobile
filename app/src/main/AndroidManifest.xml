<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"
        tools:ignore="CoarseFineLocation" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.READ_PRIVILEGED_PHONE_STATE"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.READ_PRIVILEGED_PHONE_STATE"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_logo_phiwms"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_logo_phiwms"
        android:supportsRtl="true"
        android:theme="@style/Theme.PhiWMS_Mobile"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">

    <!-- Authentification -->
    <activity
        android:name="fr.alcyons.phiwms_mobile.AuthentificationActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:configChanges="orientation|screenSize"
        android:exported="true">
        <intent-filter>
            <action android:name="android.intent.action.MAIN" />

            <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
    </activity>

    <!-- Paramètre Serveur -->
    <activity
        android:name="fr.alcyons.phiwms_mobile.ParametresServeur.ServiceParametresServeurActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:configChanges="orientation|screenSize"/>

    <!-- Navigation Activity -->
    <activity
        android:name="fr.alcyons.phiwms_mobile.Navigation.NavigationActivity"
        android:parentActivityName="fr.alcyons.phiwms_mobile.ServiceAvecConnexionActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:configChanges="orientation|screenSize"/>

    <!-- Service Réception PUI -->
    <activity
        android:name="fr.alcyons.phiwms_mobile.ReceptionPUI.ServiceReceptionPuiActivity"
        android:parentActivityName="fr.alcyons.phiwms_mobile.ServiceAvecConnexionActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:configChanges="orientation|screenSize"/>

    <activity
        android:name="fr.alcyons.phiwms_mobile.ReceptionPUI.ListeLotReceptionPuiActivity"
        android:parentActivityName="fr.alcyons.phiwms_mobile.ServiceActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:configChanges="orientation|screenSize"/>

    <activity
        android:name="fr.alcyons.phiwms_mobile.ReceptionPUI.DetailReceptionPuiActivity"
        android:parentActivityName="fr.alcyons.phiwms_mobile.ServiceActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:configChanges="orientation|screenSize"/>

    <activity
        android:name="fr.alcyons.phiwms_mobile.ReceptionPUI.CreationLotManuelReceptionPUIActivity"
        android:parentActivityName="fr.alcyons.phiwms_mobile.ServiceActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:configChanges="orientation|screenSize"/>

    <activity
        android:name="fr.alcyons.phiwms_mobile.ReceptionPUI.ZoneEtEmplacementSelecteurMultipleActivity"
        android:parentActivityName="fr.alcyons.phiwms_mobile.ServiceActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:configChanges="orientation|screenSize"/>

    <!-- Retour PUI -->
    <activity
        android:name="fr.alcyons.phiwms_mobile.RetourPUI.ServiceRetourPUIActivity"
        android:parentActivityName="fr.alcyons.phiwms_mobile.ServiceAvecConnexionActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:configChanges="orientation|screenSize"/>

    <activity
        android:name="fr.alcyons.phiwms_mobile.RetourPUI.DetailRetourPUIActivity"
        android:parentActivityName="fr.alcyons.phiwms_mobile.ServiceActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:configChanges="orientation|screenSize"/>

    <activity
        android:name="fr.alcyons.phiwms_mobile.RetourPUI.ListeEmplacementRetourPUIActivity"
        android:parentActivityName="fr.alcyons.phiwms_mobile.ServiceActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:configChanges="orientation|screenSize"/>

    <!-- Retour Fournisseur -->
    <activity
        android:name="fr.alcyons.phiwms_mobile.RetourFournisseur.ServiceRetourFournisseurActivity"
        android:parentActivityName="fr.alcyons.phiwms_mobile.ServiceAvecConnexionActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:configChanges="orientation|screenSize"/>

    <activity
        android:name="fr.alcyons.phiwms_mobile.RetourFournisseur.DetailRetourFournisseurActivity"
        android:parentActivityName="fr.alcyons.phiwms_mobile.ServiceActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:configChanges="orientation|screenSize"/>

    <!-- Barcode Activity -->
    <activity
        android:name="fr.alcyons.phiwms_mobile.BarcodeSearch.BarcodeCaptureActivity"
        android:parentActivityName="fr.alcyons.phiwms_mobile.ServiceActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:windowSoftInputMode="stateHidden"
        android:configChanges="orientation|keyboardHidden"/>

    <!-- Plan de placement -->
    <activity
        android:name="fr.alcyons.phiwms_mobile.PlanDePlacement.ListeZonesActivity"
        android:parentActivityName="fr.alcyons.phiwms_mobile.ServiceActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:windowSoftInputMode="stateHidden"
        android:configChanges="orientation|keyboardHidden"/>
    <activity
        android:name="fr.alcyons.phiwms_mobile.PlanDePlacement.ListeEmplacementActivity"
        android:parentActivityName="fr.alcyons.phiwms_mobile.ServiceActivity"
        android:theme="@style/AppTheme.NoActionBar"
        android:windowSoftInputMode="stateHidden"
        android:configChanges="orientation|keyboardHidden"/>
    </application>

</manifest>